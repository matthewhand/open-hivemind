  "/admin/mcp-servers/test": {
    "post": {
      "summary": "Test connection to an MCP server",
      "tags": [
        "Admin"
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "serverUrl": {
                  "type": "string"
                },
                "apiKey": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                }
              },
              "required": [
                "serverUrl"
              ]
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Successfully tested connection"
        },
        "400": {
          "description": "Validation error"
        },
        "403": {
          "description": "Security warning - URL blocked"
        }
      }
    }
  },
