        "404": {
          "description": "MCP provider not found"
        }
      }
    },
    "delete": {
      "summary": "Delete MCP provider",
      "tags": [
        "MCP"
      ],
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string"
          },
          "description": "Provider ID"
        }
      ],
      "responses": {
        "200": {
          "description": "MCP provider deleted successfully"
        },
        "404": {
          "description": "MCP provider not found"
        }
      }
    }
  },
