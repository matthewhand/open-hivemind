{
  "/api/activity/messages": {
    "get": {
      "summary": "Get filtered message activity",
      "tags": [
        "Activity"
      ],
      "parameters": [
        {
          "name": "agentId",
          "in": "query",
          "required": false,
          "schema": {
            "type": "string"
          },
          "description": "Filter by agent ID"
        },
        {
          "name": "messageProvider",
          "in": "query",
          "required": false,
          "schema": {
            "type": "string"
          },
          "description": "Filter by message provider"
        },
        {
          "name": "llmProvider",
          "in": "query",
          "required": false,
          "schema": {
            "type": "string"
          },
          "description": "Filter by LLM provider"
        },
        {
          "name": "startDate",
          "in": "query",
          "required": false,
          "schema": {
            "type": "string"
          },
          "description": "ISO datetime start filter"
        },
        {
          "name": "endDate",
          "in": "query",
          "required": false,
          "schema": {
            "type": "string"
          },
          "description": "ISO datetime end filter"
        },
        {
          "name": "limit",
          "in": "query",
          "required": false,
          "schema": {
            "type": "string"
          },
          "description": "Limit results"
        },
        {
          "name": "offset",
          "in": "query",
          "required": false,
          "schema": {
            "type": "string"
          },
          "description": "Offset for pagination"
        }
      ],
      "responses": {
        "200": {
          "description": "Message activity data"
        },
        "503": {
          "description": "Database not connected"
        }
      }
    }
  },
