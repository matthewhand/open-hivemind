{
  "$schema": "../docs/schemas/memory-profiles.schema.json",
  "_comment": "Copy to config/memory-profiles.json and adjust. See docker-compose.override.example.yml for self-hosted Mem0 setup.",

  "local-mem0": {
    "provider": "mem0",
    "baseUrl": "http://mem0:8000",
    "apiKey": "not-needed-unless-ADMIN_API_KEY-is-set",
    "userId": "default",
    "timeoutMs": 10000
  },

  "cloud-mem0": {
    "provider": "mem0",
    "apiKey": "${MEM0_API_KEY}",
    "userId": "default"
  }
}
