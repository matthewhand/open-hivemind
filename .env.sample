# ==============================================================================
# Open-Hivemind - Environment Configuration (.env)
# ==============================================================================
# This file provides an example setup for configuring your AI agents.
# All available environment variables with their descriptions, required status,
# and example formats are listed below.
# ==============================================================================

# ------------------------------------------------------------------------------
# System & General Server Configuration
# ------------------------------------------------------------------------------

# NODE_ENV: The environment mode (development, production, test).
# Optional. Default: development
NODE_ENV=development

# PORT: The port number the main server listens on.
# Optional. Default: 3000
PORT=3000

# BASE_URL: The base URL of the deployment (used for links and webhooks).
# Optional. Default: http://localhost:3000
BASE_URL=http://localhost:3000

# LOG_LEVEL: Standard logging level (error, warn, info, debug, trace).
# Optional. Default: info
LOG_LEVEL=info

# ERROR_LOG_PATH: File path for logging errors.
# Optional. Default: ./logs/error.log
# ERROR_LOG_PATH=./logs/error.log

# NODE_CONFIG_DIR: Override directory for static configuration files.
# Optional. Default: ./config
# NODE_CONFIG_DIR=./config

# DEBUG: Show extended diagnostic debug info (e.g. app:*, express:*).
# Optional. Default: (none)
# DEBUG=app:*

# DEMO_MODE: Enable restricted demonstration mode (blocks structural edits).
# Optional. Default: false
DEMO_MODE=false


# LOW_MEMORY_MODE: Reduce memory usage by limiting cache sizes and history.
# Optional. Default: false
# LOW_MEMORY_MODE=false

# HTTP_ENABLED: Enables the HTTP server. If false, only messenger bots run.
# Optional. Default: true
# HTTP_ENABLED=true

# HTTP_ALLOW_ALL_IPS: If true, disables IP whitelisting for the HTTP server.
# Optional. Default: false
# HTTP_ALLOW_ALL_IPS=false

# ENABLE_VITE_DEV: If true, runs Vite dev server along with backend in dev mode.
# Optional. Default: true
# ENABLE_VITE_DEV=true

# SKIP_MESSENGERS: If true, disables starting messenger bots.
# Optional. Default: false
# SKIP_MESSENGERS=false

# SUPPRESS_HEALTH_LOGS: If true, suppresses standard health check logs to reduce noise.
# Optional. Default: true
# SUPPRESS_HEALTH_LOGS=true

# HIVEMIND_PLUGINS_DIR: Directory to load plugins from.
# Optional. Default: ~/.hivemind/plugins
# HIVEMIND_PLUGINS_DIR=

# DATABASE_URL: PostgreSQL connection string (if using postgres memory/auth).
# Optional. Example: postgres://user:pass@localhost:5432/db
# DATABASE_URL=

# ------------------------------------------------------------------------------
# Security & Authentication
# ------------------------------------------------------------------------------

# ADMIN_PASSWORD: Set an admin password for initial login.
# Required in production. Example: your-secure-admin-password
ADMIN_PASSWORD=your-secure-admin-password

# SESSION_SECRET: Cryptographic key used to encrypt stateful user sessions.
# Required in production. Example: your-secure-session-secret
SESSION_SECRET=your-secure-session-secret

# JWT_SECRET: Secret for signing JWT access tokens.
# Required in production. Example: your-jwt-access-secret
JWT_SECRET=your-jwt-access-secret

# JWT_REFRESH_SECRET: Secret for signing JWT refresh tokens.
# Required in production. Example: your-jwt-refresh-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret

# API_AUTH_TOKEN: Static token for authenticating programmatic API requests.
# Optional. Example: your-api-auth-token
API_AUTH_TOKEN=your-api-auth-token

# ADMIN_IP_WHITELIST: Comma-separated list of IPs allowed to bypass or access admin panel.
# Optional. Default: 127.0.0.1
ADMIN_IP_WHITELIST=127.0.0.1

# ALLOW_LOCALHOST_ADMIN: Allow localhost access to admin panel.
# Optional. Default: true
ALLOW_LOCALHOST_ADMIN=true

# ALLOW_LOCAL_NETWORK_ACCESS: Allow local network access to admin panel.
# Optional. Default: false
ALLOW_LOCAL_NETWORK_ACCESS=false

# CORS_ORIGIN: CORS origin allowed to access the API.
# Optional. Default: *
CORS_ORIGIN=*

# TRUST_PROXY: Proxy trust setting for Express behind load balancers.
# Optional. Default: false
TRUST_PROXY=false

# TRUSTED_PROXIES: Comma-separated list of trusted proxies.
# Optional. Default: (none)
# TRUSTED_PROXIES=

# SESSION_COOKIE_NAME: Custom name for the session cookie.
# Optional. Example: hivemind.sid
# SESSION_COOKIE_NAME=hivemind.sid

# SESSION_MAX_AGE: Session lifetime in milliseconds.
# Optional. Default: 86400000 (24 hours)
# SESSION_MAX_AGE=86400000

# SESSION_IDLE_TIMEOUT: Session idle timeout in milliseconds.
# Optional. Default: 1800000 (30 minutes)
# SESSION_IDLE_TIMEOUT=1800000

# SESSION_STORE_MAX_SESSIONS: Max sessions to keep in memory (if using in-memory store).
# Optional. Default: 10000
# SESSION_STORE_MAX_SESSIONS=10000

# SESSION_STORE_CLEANUP_INTERVAL_MS: Interval to clear expired sessions.
# Optional. Default: 300000 (5 minutes)
# SESSION_STORE_CLEANUP_INTERVAL_MS=300000

# SECRET: Generic fallback secret string used for encryption or validation.
# Optional. Example: your-generic-secret
# SECRET=

# CSRF_SKIP_IN_TEST: Skip CSRF token validation when running in tests.
# Optional. Default: false
# CSRF_SKIP_IN_TEST=false

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------

# REDIS_URL: Redis connection string used for caching, sessions, and rate limit stores.
# Optional. Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# RATE_LIMIT_MAX: Max requests per window overall.
# Optional. Default: 100
# RATE_LIMIT_MAX=100

# RATE_LIMIT_WINDOW_MS: Window size in milliseconds for generic rate limit.
# Optional. Default: 60000
# RATE_LIMIT_WINDOW_MS=60000

# RATE_LIMIT_API_MAX: Max requests per window for the API endpoints.
# Optional. Default: 100
RATE_LIMIT_API_MAX=100

# RATE_LIMIT_API_WINDOW_MS: Window size in ms for API endpoints rate limit.
# Optional. Default: 60000 (1 minute)
RATE_LIMIT_API_WINDOW_MS=60000

# RATE_LIMIT_AUTH_MAX: Max requests per window for Authentication endpoints.
# Optional. Default: 5
RATE_LIMIT_AUTH_MAX=5

# RATE_LIMIT_AUTH_WINDOW_MS: Window size in ms for Auth rate limit.
# Optional. Default: 300000 (5 minutes)
RATE_LIMIT_AUTH_WINDOW_MS=300000

# RATE_LIMIT_ADMIN_MAX: Max requests for Admin specific endpoints.
# Optional. Default: 100
# RATE_LIMIT_ADMIN_MAX=100

# RATE_LIMIT_ADMIN_WINDOW_MS: Admin endpoints window size in ms.
# Optional. Default: 60000
# RATE_LIMIT_ADMIN_WINDOW_MS=60000

# RATE_LIMIT_CONFIG_MAX: Max requests per window for config endpoints.
# Optional. Default: 10
# RATE_LIMIT_CONFIG_MAX=10

# RATE_LIMIT_CONFIG_WINDOW_MS: Window size in ms for config rate limit.
# Optional. Default: 300000 (5 minutes)
# RATE_LIMIT_CONFIG_WINDOW_MS=300000

# DISABLE_RATE_LIMIT: Completely disable all rate limiting logic.
# Optional. Default: false
DISABLE_RATE_LIMIT=false


# RATE_LIMITER_MAX_IDENTIFIERS: Max unique IP/IDs to track for general rate limiting.
# Optional. Default: 10000
# RATE_LIMITER_MAX_IDENTIFIERS=10000

# RATE_LIMITER_MAX_ATTEMPTS_PER_ID: Max request attempts tracked per identifier.
# Optional. Default: 100
# RATE_LIMITER_MAX_ATTEMPTS_PER_ID=100

# ------------------------------------------------------------------------------
# Multi-Bot Configuration (Prefix: BOTS_<BOT_NAME>_)
# ------------------------------------------------------------------------------
# NEW MULTI-BOT CAPABILITY:
# You can now run multiple bots simultaneously across different platforms and LLMs.
# To configure a specific bot, prefix its configuration keys with: BOTS_<BOT_NAME>_
#
# Supported Message Providers: discord, slack, mattermost, webhook
# Supported LLM Providers: openai, flowise, openwebui, perplexity, replicate, n8n, openswarm

# Example Bot 1: "Alpha" (Discord + OpenAI)
# Optional.
BOTS_ALPHA_MESSAGE_PROVIDER=discord
BOTS_ALPHA_LLM_PROVIDER=openai
BOTS_ALPHA_PERSONA=default
BOTS_ALPHA_DISCORD_BOT_TOKEN=your-discord-bot-token-here
BOTS_ALPHA_DISCORD_CLIENT_ID=your-discord-client-id
BOTS_ALPHA_DISCORD_GUILD_ID=your-discord-guild-id
BOTS_ALPHA_DISCORD_CHANNEL_ID=your-default-channel-id
BOTS_ALPHA_OPENAI_API_KEY=sk-your-openai-api-key
BOTS_ALPHA_OPENAI_MODEL=gpt-4o
BOTS_ALPHA_OPENAI_BASE_URL=https://api.openai.com/v1/
BOTS_ALPHA_OPENAI_SYSTEM_PROMPT="You are Alpha, a helpful Discord assistant."

# Example Bot 2: "Beta" (Slack + Flowise)
# Optional.
BOTS_BETA_MESSAGE_PROVIDER=slack
BOTS_BETA_LLM_PROVIDER=flowise
BOTS_BETA_PERSONA=tech_support
BOTS_BETA_SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
BOTS_BETA_SLACK_APP_TOKEN=xapp-your-slack-app-token
BOTS_BETA_SLACK_SIGNING_SECRET=your-slack-signing-secret
BOTS_BETA_FLOWISE_API_BASE_URL=http://localhost:3000/api/v1

# FLOWISE_BASE_URL: Base URL for Flowise instance (alias).
# Optional. Example: http://localhost:3000
# FLOWISE_BASE_URL=
BOTS_BETA_FLOWISE_API_KEY=your-flowise-api-key

# ------------------------------------------------------------------------------
# Legacy / Global Configuration (Optional)
# ------------------------------------------------------------------------------
# If you only intend to run a single bot and do not want to use the BOTS_<NAME>_
# prefix, you can use these global fallbacks.

# MESSAGE_PROVIDER: Default message provider if no bot-specific one is set.
# Optional. Default: discord
MESSAGE_PROVIDER=discord

# MESSAGE_USERNAME_OVERRIDE: Override name for the bot's messages.
# Optional. Example: OpenHivemind
# MESSAGE_USERNAME_OVERRIDE=OpenHivemind

# --- Discord ---
# DISCORD_BOT_TOKEN: Global fallback Discord bot token.
# Optional (but required if Discord is primary). Example: your-discord-token
DISCORD_BOT_TOKEN=your-discord-token

# DISCORD_CLIENT_ID: Discord OAuth Client ID.
# Optional. Example: your-discord-client-id
# DISCORD_CLIENT_ID=your-discord-client-id

# DISCORD_GUILD_ID: Target Discord Guild (Server) ID.
# Optional. Example: your-discord-guild-id
# DISCORD_GUILD_ID=your-discord-guild-id

# DISCORD_CHANNEL_ID: Default Discord text channel for system broadcasts.
# Optional. Example: your-default-channel-id
# DISCORD_CHANNEL_ID=your-default-channel-id

# DISCORD_CHAT_CHANNEL_ID: Main default text channel for bot responses.
# Optional. Example: your-discord-chat-channel-id
# DISCORD_CHAT_CHANNEL_ID=

# DISCORD_TOKEN: Token for Discord bot (alias for DISCORD_BOT_TOKEN).
# Optional. Example: your-discord-token
# DISCORD_TOKEN=

# DISCORD_VOICE_CHANNEL_ID: Target voice channel for audio extensions.
# Optional. Example: your-voice-channel-id
# DISCORD_VOICE_CHANNEL_ID=

# DISCORD_MESSAGE_HISTORY_LIMIT: Cap fetched history limits.
# Optional. Default: 10
# DISCORD_MESSAGE_HISTORY_LIMIT=10

# DISCORD_AUDIO_FILE_PATH: Path to audio files for Discord commands.
# Optional. Example: ./audio
# DISCORD_AUDIO_FILE_PATH=

# DISCORD_CHANNEL_BONUSES: Channel-specific bonuses. Supports CSV (ch1:1.5,ch2:0.8) or JSON ({"ch1":1.5,"ch2":0.8}). Range: 0.0-2.0.
# Optional. Example: ch1:1.5,ch2:0.8
# DISCORD_CHANNEL_BONUSES=

# DISCORD_DEFAULT_CHANNEL_ID: Default channel ID for outgoing messages.
# Optional. Example: 123456789
# DISCORD_DEFAULT_CHANNEL_ID=

# DISCORD_INTER_PART_DELAY_MS: Delay between parts of a multi-part message (ms).
# Optional. Default: 500
# DISCORD_INTER_PART_DELAY_MS=500

# DISCORD_LOGGING_ENABLED: Enable logging to files.
# Optional. Default: false
# DISCORD_LOGGING_ENABLED=false

# DISCORD_MAX_MESSAGE_LENGTH: Maximum characters per Discord message chunk. Range: 1-2000.
# Optional. Default: 2000
# DISCORD_MAX_MESSAGE_LENGTH=2000

# DISCORD_MESSAGE_PROCESSING_DELAY_MS: Delay for processing messages (ms).
# Optional. Default: 0
# DISCORD_MESSAGE_PROCESSING_DELAY_MS=0

# DISCORD_PRIORITY_CHANNEL: Default channel ID considered priority.
# Optional. Example: 123456789
# DISCORD_PRIORITY_CHANNEL=

# DISCORD_PRIORITY_CHANNEL_BONUS: Bonus applied to priority channels. Range: 0.0-2.0.
# Optional. Default: 1.1
# DISCORD_PRIORITY_CHANNEL_BONUS=1.1

# DISCORD_TYPING_DELAY_MAX_MS: Maximum delay (ms) before starting typing simulation.
# Optional. Default: 3000
# DISCORD_TYPING_DELAY_MAX_MS=3000

# DISCORD_UNSOLICITED_CHANCE_MODIFIER: Modifier for unsolicited message chance. Range: -1.0-1.0.
# Optional. Default: 0.0
# DISCORD_UNSOLICITED_CHANCE_MODIFIER=0.0

# DISCORD_WELCOME_MESSAGE: Message to send when bot joins a server/channel.
# Optional. Example: Hello World!
# DISCORD_WELCOME_MESSAGE=


# --- Slack ---
# SLACK_BOT_TOKEN: Slack bot token (starts with xoxb-).
# Optional (but required if Slack is primary). Example: xoxb-your-slack-bot-token
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# SLACK_APP_TOKEN: Slack app-level token (starts with xapp-) for Socket mode.
# Optional. Example: xapp-your-slack-app-token
# SLACK_APP_TOKEN=xapp-your-slack-app-token

# SLACK_SIGNING_SECRET: Slack signing secret for request validation.
# Optional. Example: your-slack-signing-secret
# SLACK_SIGNING_SECRET=your-slack-signing-secret

# SLACK_DEFAULT_CHANNEL_ID: Default Slack text channel.
# Optional. Example: C12345678
# SLACK_DEFAULT_CHANNEL_ID=

# WELCOME_RESOURCE_URL: URL used in Slack welcome messages.
# Optional. Default: https://university.example.com/resources
# WELCOME_RESOURCE_URL=https://university.example.com/resources

# --- Mattermost ---
# MATTERMOST_SERVER_URL: Base URL of Mattermost server.
# Optional. Example: https://mattermost.example.com
# MATTERMOST_SERVER_URL=https://mattermost.example.com

# MATTERMOST_URL: Mattermost server URL (alias).
# Optional. Example: https://mattermost.example.com
# MATTERMOST_URL=

# MATTERMOST_TOKEN: Mattermost bot access token.
# Optional (but required if Mattermost is primary). Example: your-mattermost-bot-token
# MATTERMOST_TOKEN=your-mattermost-bot-token

# --- Telegram ---
# TELEGRAM_BOT_TOKEN: Telegram bot access token.
# Optional. Example: your-telegram-token
# TELEGRAM_BOT_TOKEN=your-telegram-token

# --- Webhook (Custom Integrations) ---
# WEBHOOK_ENABLED: Enables inbound webhook listeners.
# Optional. Default: false
# WEBHOOK_ENABLED=false

# WEBHOOK_PORT: Port specifically for webhook endpoints if separate.
# Optional. Example: 3001
# WEBHOOK_PORT=

# WEBHOOK_IP_WHITELIST: Comma-separated list of IPs allowed to call webhook endpoints.
# ⚠️ BREAKING CHANGE: An empty value now BLOCKS all requests (default-deny).
# Previously an empty value allowed all IPs. To restore open access use: 0.0.0.0/0
# Supports exact IPv4 and IPv6 addresses. CIDR notation is NOT currently supported.
# Example (restrict to two IPs): WEBHOOK_IP_WHITELIST=203.0.113.10,203.0.113.11
# Example (loopback only):       WEBHOOK_IP_WHITELIST=127.0.0.1,::1,::ffff:127.0.0.1
# WEBHOOK_IP_WHITELIST=

# ------------------------------------------------------------------------------
# Global LLM Providers Configs
# ------------------------------------------------------------------------------

# LLM_PROVIDER: Default LLM provider (openai, flowise, openwebui, perplexity, replicate, n8n, openswarm, ollama).
# Optional. Default: openai
LLM_PROVIDER=openai

# --- OpenAI ---
# OPENAI_API_KEY: Default OpenAI API key.
# Optional (required if LLM_PROVIDER is openai). Example: sk-your-openai-api-key
OPENAI_API_KEY=your-openai-api-key

# OPENAI_BASE_URL: Default OpenAI API base URL (can be customized for compatible APIs like vLLM).
# Optional. Default: https://api.openai.com/v1/
OPENAI_BASE_URL=https://api.openai.com/v1/

# OPENAI_MODEL: Default OpenAI model.
# Optional. Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# OPENAI_SYSTEM_PROMPT: Global system prompt for OpenAI.
# Optional. Example: You are a helpful AI assistant.
# OPENAI_SYSTEM_PROMPT="You are a helpful AI assistant."

# OPENAI_MAX_TOKENS: Generation max token limit.
# Optional. Example: 4096
# OPENAI_MAX_TOKENS=

# --- Flowise ---
# FLOWISE_API_BASE_URL: Base API URL for Flowise instance.
# Optional. Default: http://localhost:3000/api/v1
FLOWISE_API_BASE_URL=http://localhost:3000/api/v1

# FLOWISE_API_KEY: Flowise API key.
# Optional. Example: your-flowise-api-key
FLOWISE_API_KEY=your-flowise-api-key

# FLOWISE_CONVERSATION_CHATFLOW_ID: Default conversational chatflow ID.
# Optional. Example: your-conversation-chatflow-id
# FLOWISE_CONVERSATION_CHATFLOW_ID=

# FLOWISE_COMPLETION_CHATFLOW_ID: Default completion chatflow ID.
# Optional. Example: your-completion-chatflow-id
# FLOWISE_COMPLETION_CHATFLOW_ID=

# --- OpenWebUI ---
# OPENWEBUI_API_URL: Base API URL for OpenWebUI instance.
# Optional. Example: http://localhost:8080/api/v1
# OPENWEBUI_API_URL=http://localhost:8080/api/v1

# OPENWEBUI_BASE_URL: Base URL for OpenWebUI instance (alias).
# Optional. Example: http://localhost:8080
# OPENWEBUI_BASE_URL=

# OPENWEBUI_API_KEY: API Key for OpenWebUI.
# Optional. Example: your-openwebui-api-key
# OPENWEBUI_API_KEY=your-openwebui-api-key

# OPEN_WEBUI_MODEL: Target model for OpenWebUI requests.
# Optional. Example: llama3
# OPEN_WEBUI_MODEL=

# --- Ollama ---
# OLLAMA_BASE_URL: Target url for standard local Ollama deployment.
# Optional. Example: http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434

# OLLAMA_MODEL: Target model running on local Ollama.
# Optional. Example: llama3.1
# OLLAMA_MODEL=llama3.1

# --- Replicate ---
# REPLICATE_API_TOKEN: API token for the Replicate platform.
# Optional. Example: your-replicate-api-token
# REPLICATE_API_TOKEN=your-replicate-api-token

# REPLICATE_MODEL_VERSION: Specific image generation or text generation version hash.
# Optional. Example: your-replicate-model-version
# REPLICATE_MODEL_VERSION=your-replicate-model-version

# REPLICATE_WEBHOOK_URL: Webhook URL Replicate should POST updates to.
# Optional. Example: http://your-domain.com/replicate/webhook
# REPLICATE_WEBHOOK_URL=

# REPLICATE_DEFAULT_PROMPT: Default prompt for Replicate generations if none provided.
# Optional. Default: Please describe this image
# REPLICATE_DEFAULT_PROMPT=

# --- OpenSwarm ---
# OPENSWARM_API_KEY: Swarm API authentication key.
# Optional. Example: your-openswarm-api-key
# OPENSWARM_API_KEY=

# OPENSWARM_BASE_URL: Target URL for swarm operations.
# Optional. Example: http://localhost:8000/v1
# OPENSWARM_BASE_URL=http://localhost:8000/v1

# OPENSWARM_TEAM: Multi-agent logical team name.
# Optional. Example: default-team
# OPENSWARM_TEAM=default-team

# OPENSWARM_WEBUI_URL: URL to the OpenSwarm WebUI for swarm installers.
# Optional. Default: http://localhost:8002
# OPENSWARM_WEBUI_URL=http://localhost:8002

# --- Memory providers ---
# Open-Hivemind supports multiple memory providers with different embedding strategies.
# All providers support custom OpenAI-compatible embedding endpoints.

# === Mem0 (Local SDK with fact extraction) ===
# Mem0 uses LLM for automatic fact extraction + embeddings for vector search.
# Requires: OpenAI API key (or compatible endpoint)

# MEM0_API_KEY: OpenAI API key for LLM fact extraction and embeddings.
# Optional. Example: sk-your-openai-api-key
# MEM0_API_KEY=your-openai-api-key

# MEM0_LLM_PROVIDER: LLM provider for fact extraction (openai, anthropic).
# Optional. Default: openai
# MEM0_LLM_PROVIDER=openai

# MEM0_LLM_MODEL: Model for fact extraction.
# Optional. Default: gpt-4o-mini
# MEM0_LLM_MODEL=gpt-4o-mini

# MEM0_LLM_BASE_URL: Custom LLM endpoint (for vLLM, Ollama, etc.).
# Optional. Example: http://localhost:8000/v1
# MEM0_LLM_BASE_URL=http://localhost:8000/v1

# MEM0_EMBEDDER_MODEL: Embedding model name.
# Optional. Default: text-embedding-3-small
# MEM0_EMBEDDER_MODEL=text-embedding-3-small

# MEM0_EMBEDDER_BASE_URL: Custom embedding endpoint (OpenAI-compatible).
# Use this to point to vLLM, Ollama, Voyage, or any OpenAI-compatible embedding server.
# Optional. Example: http://localhost:8000/v1
# MEM0_EMBEDDER_BASE_URL=http://localhost:8000/v1

# MEM0_VECTOR_STORE: Vector store provider (memory, pgvector, pinecone).
# Optional. Default: memory
# MEM0_VECTOR_STORE=pgvector

# MEM0_PGVECTOR_HOST: PostgreSQL host for Mem0 vector store.
# Optional. Default: localhost
# MEM0_PGVECTOR_HOST=localhost

# MEM0_PGVECTOR_PORT: PostgreSQL port for Mem0 vector store.
# Optional. Default: 5432
# MEM0_PGVECTOR_PORT=5432

# MEM0_PGVECTOR_USER: PostgreSQL user for Mem0 vector store.
# Optional. Default: hivemind
# MEM0_PGVECTOR_USER=hivemind

# MEM0_PGVECTOR_PASSWORD: PostgreSQL password for Mem0 vector store.
# Required if using pgvector. Example: your-postgres-password
# MEM0_PGVECTOR_PASSWORD=your-postgres-password

# MEM0_PGVECTOR_DATABASE: PostgreSQL database name for Mem0 vector store.
# Optional. Default: hivemind
# MEM0_PGVECTOR_DATABASE=hivemind

# MEM0_PGVECTOR_COLLECTION: Collection name for Mem0 memories.
# Optional. Default: mem0_memories
# MEM0_PGVECTOR_COLLECTION=mem0_memories

# === Mem4ai (External API with adaptive personalization) ===
# Mem4ai is an external REST API for memory management.
# Requires: Mem4ai API URL and key

# MEM4AI_API_URL: Mem4ai API base URL.
# Optional. Example: https://api.mem4ai.com/v1
# MEM4AI_API_URL=https://api.mem4ai.com/v1

# MEM4AI_API_KEY: Mem4ai API key.
# Optional. Example: your-mem4ai-api-key
# MEM4AI_API_KEY=your-mem4ai-api-key

# MEM4AI_EMBEDDING_PROVIDER_ID: Reference to LLM provider for embeddings.
# Optional. Example: openai
# MEM4AI_EMBEDDING_PROVIDER_ID=openai

# MEM4AI_LLM_PROFILE_KEY: LLM profile key for embedding configuration.
# Optional. Example: default
# MEM4AI_LLM_PROFILE_KEY=default

# === MemVault (PostgreSQL + pgvector) ===
# Self-hosted RAG memory with hybrid vector/recency scoring.
# Requires: PostgreSQL with pgvector extension

# MEMVAULT_HOST: PostgreSQL server hostname.
# Optional. Default: localhost
# MEMVAULT_HOST=localhost

# MEMVAULT_PORT: PostgreSQL server port.
# Optional. Default: 5432
# MEMVAULT_PORT=5432

# MEMVAULT_DATABASE: PostgreSQL database name.
# Optional. Default: hivemind
# MEMVAULT_DATABASE=hivemind

# MEMVAULT_USER: PostgreSQL username.
# Optional. Default: hivemind
# MEMVAULT_USER=hivemind

# MEMVAULT_PASSWORD: PostgreSQL password.
# Required. Example: your-postgres-password
# MEMVAULT_PASSWORD=your-postgres-password

# MEMVAULT_VECTOR_DIMENSION: Embedding vector dimension.
# Optional. Default: 1536 (OpenAI text-embedding-3-small)
# MEMVAULT_VECTOR_DIMENSION=1536

# MEMVAULT_EMBEDDING_ENDPOINT: Custom embedding endpoint URL.
# Optional. Example: http://localhost:8000/v1
# MEMVAULT_EMBEDDING_ENDPOINT=http://localhost:8000/v1

# MEMVAULT_EMBEDDING_API_KEY: API key for embedding endpoint.
# Optional. Example: sk-your-embedding-key
# MEMVAULT_EMBEDDING_API_KEY=your-embedding-api-key

# MEMVAULT_EMBEDDING_MODEL: Embedding model name.
# Optional. Default: text-embedding-3-small
# MEMVAULT_EMBEDDING_MODEL=text-embedding-3-small

# MEMVAULT_EMBEDDING_PROVIDER_ID: Reference to LLM provider for embeddings.
# Optional. Example: openai
# MEMVAULT_EMBEDDING_PROVIDER_ID=openai

# MEMVAULT_LLM_PROFILE_KEY: LLM profile key for embedding configuration.
# Optional. Example: default
# MEMVAULT_LLM_PROFILE_KEY=default

# === Redis (for caching and sessions) ===

# REDIS_URL: Redis connection string.
# Optional. Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# Agent Behaviors & Modifiers
# ------------------------------------------------------------------------------

# MESSAGE_INTERROBANG_BONUS: Bonus chance modifier for interrobang messages (e.g., !?).
# Optional. Default: 0.1
MESSAGE_INTERROBANG_BONUS=0.1

# MESSAGE_MENTION_BONUS: Bonus chance when the bot is directly mentioned.
# Optional. Default: 0.5
MESSAGE_MENTION_BONUS=0.5

# MESSAGE_BOT_RESPONSE_MODIFIER: Modifier for responding to other bot messages (negative to reduce).
# Optional. Default: -1.0
MESSAGE_BOT_RESPONSE_MODIFIER=-1.0

# MESSAGE_PRIORITY_CHANNEL_BONUS: Bonus multiplier for responding in priority channels.
# Optional. Default: 0.8
MESSAGE_PRIORITY_CHANNEL_BONUS=0.8

# MESSAGE_PRIORITY_CHANNEL: Target priority channel ID.
# Optional. Example: your-priority-channel-id
# MESSAGE_PRIORITY_CHANNEL=your-priority-channel-id

# MESSAGE_RECENT_ACTIVITY_DECAY_RATE: Decay rate for message response based on recent history.
# Optional. Default: 0.5
MESSAGE_RECENT_ACTIVITY_DECAY_RATE=0.5

# MESSAGE_ACTIVITY_TIME_WINDOW: Time window (in milliseconds) used for activity calculations.
# Optional. Default: 300000 (5 minutes)
MESSAGE_ACTIVITY_TIME_WINDOW=300000

# MESSAGE_WAKEWORDS: Comma-separated wakewords that guarantee a response from the bot.
# Optional. Example: !help,!ping,!echo
MESSAGE_WAKEWORDS=!help,!ping,!echo

# BOTS: Global configuration string for multi-bot setup.
# Optional.
# BOTS=

# FORCE_REPLY: If true, the bot attempts to force a reply to all messages.
# Optional. Default: false
# FORCE_REPLY=false

# BOT_GLOBAL_SCORE_LIMIT: Threshold for bot reply fatigue.
# Optional. Default: 2.0
# BOT_GLOBAL_SCORE_LIMIT=2.0

# CHANNEL_BONUSES: JSON/String config to adjust reply chances per channel.
# Optional.
# CHANNEL_BONUSES=

# CHANNEL_PRIORITIES: JSON/String config defining priority channels.
# Optional.
# CHANNEL_PRIORITIES=

# OUTGOING_RATE_LIMITER_MAX_CHANNELS: Memory size cap for the outgoing message rate limiter.
# Optional. Default: 5000
# OUTGOING_RATE_LIMITER_MAX_CHANNELS=5000

# OUTGOING_RATE_LIMITER_MAX_TIMESTAMPS: Max timestamps to retain per channel for rate limiting.
# Optional. Default: 100
# OUTGOING_RATE_LIMITER_MAX_TIMESTAMPS=100

# ENABLE_WELCOME_MESSAGE: Send a welcome message when the bot joins/starts.
# Optional. Default: false
# ENABLE_WELCOME_MESSAGE=false

# WELCOME_MESSAGE_TEXT: Custom welcome message text.
# Optional. Default: 🤖 I am now online and ready to assist.
# WELCOME_MESSAGE_TEXT=

# STARTUP_LOG_SYSTEM_PROMPT: Whether to log the system prompt on startup (none, preview, full).
# Optional. Default: preview
# STARTUP_LOG_SYSTEM_PROMPT=preview

# STARTUP_LOG_SYSTEM_PROMPT_PREVIEW_CHARS: Max characters to show in prompt preview.
# Optional. Default: 280
# STARTUP_LOG_SYSTEM_PROMPT_PREVIEW_CHARS=280

# LOG_SUMMARY_LLM: Provide an LLM model name (e.g. gpt-4o) to enable semantic log summarization.
# Optional.
# LOG_SUMMARY_LLM=

# ------------------------------------------------------------------------------
# Idle Response Configuration
# ------------------------------------------------------------------------------

# IDLE_RESPONSE_ENABLED: Enable or disable proactive idle responses.
# Optional. Default: false
IDLE_RESPONSE_ENABLED=false

# IDLE_RESPONSE_MIN_DELAY: Minimum delay (in ms) before sending an idle response.
# Optional. Default: 600000 (10 minutes)
IDLE_RESPONSE_MIN_DELAY=600000

# IDLE_RESPONSE_MAX_DELAY: Maximum delay (in ms) before sending an idle response.
# Optional. Default: 3600000 (1 hour)
IDLE_RESPONSE_MAX_DELAY=3600000

# DUPLICATE_DETECTOR_CLEANUP_INTERVAL_MS: Interval to clear duplicate messaging caches.
# Optional. Default: 300000
# DUPLICATE_DETECTOR_CLEANUP_INTERVAL_MS=300000

# DUPLICATE_DETECTOR_MAX_CHANNELS: Memory size cap for the duplicate message detector state.
# Optional. Default: 100
# DUPLICATE_DETECTOR_MAX_CHANNELS=100


# ------------------------------------------------------------------------------
# API & Body Parsing Options
# ------------------------------------------------------------------------------

# BODY_PARSER_JSON_LIMIT: Limit for standard JSON payload requests.
# Optional. Default: 1mb
# BODY_PARSER_JSON_LIMIT=1mb

# BODY_PARSER_LARGE_JSON_LIMIT: Limit for large JSON payloads (e.g., uploads).
# Optional. Default: 10mb
# BODY_PARSER_LARGE_JSON_LIMIT=10mb

# BODY_PARSER_URL_ENCODED_LIMIT: Limit for url-encoded payload requests.
# Optional. Default: 1mb
# BODY_PARSER_URL_ENCODED_LIMIT=1mb

# BODY_PARSER_WEBHOOK_LIMIT: Limit for webhook endpoint payloads.
# Optional. Default: 10mb
# BODY_PARSER_WEBHOOK_LIMIT=10mb

# ------------------------------------------------------------------------------
# Monitoring & Alerting
# ------------------------------------------------------------------------------

# ALERT_MANAGER_MAX_ALERTS: Max alerts to store in memory.
# Optional. Default: 1000
# ALERT_MANAGER_MAX_ALERTS=1000

# ALERT_MANAGER_MAX_FAILURE_COUNTS: Max unique failure events to track.
# Optional. Default: 100
# ALERT_MANAGER_MAX_FAILURE_COUNTS=100

# ------------------------------------------------------------------------------
# Tooling & Extensibility
# ------------------------------------------------------------------------------

# ALLOW_ALL_TOOL_USERS: Allows all users to execute commands/tools.
# Optional. Default: false
# ALLOW_ALL_TOOL_USERS=false

# ALLOWED_TOOL_USERS: Comma-separated list of User IDs allowed to execute tools.
# Optional.
# ALLOWED_TOOL_USERS=

# ------------------------------------------------------------------------------
# Frontend / Client Configuration (Vite)
# ------------------------------------------------------------------------------

# VITE_API_BASE_URL: URL used by the React client to make backend API calls.
# Optional. Example: http://localhost:3000
# VITE_API_BASE_URL=

# VITE_AUTO_LOGIN: Enable auto-login bypass for development mode in the UI.
# Optional. Default: false
# VITE_AUTO_LOGIN=false

# ------------------------------------------------------------------------------
# System & General Config Auto-Discovered Additions
# ------------------------------------------------------------------------------

# BOT_ID: Bot identifier
# Optional. Default: slack-bot
# BOT_ID=slack-bot

# DEFAULT_EMBEDDING_PROVIDER: Default embedding-capable LLM provider/profile id
# Optional. Default:
# DEFAULT_EMBEDDING_PROVIDER=

# DISABLE_DELAYS: When true, skips all artificial delays (reading delay, post-inference typing simulation). Typing indicator still shows during actual LLM inference. Per-bot override: BOTS_{name}_DISABLE_DELAYS=true
# Optional. Default: false
# DISABLE_DELAYS=false

# DISCORD_AUDIO_FILE_PATH: Path to audio files for Discord commands
# Optional. Default: audio.wav
# DISCORD_AUDIO_FILE_PATH=audio.wav

# DISCORD_CHANNEL_BONUSES: No description provided
# Optional. Default:
# DISCORD_CHANNEL_BONUSES=

# DISCORD_DEFAULT_CHANNEL_ID: Default channel ID for outgoing messages
# Optional. Default:
# DISCORD_DEFAULT_CHANNEL_ID=

# DISCORD_INTER_PART_DELAY_MS: Delay between multipart messages (ms)
# Optional. Default: 1000
# DISCORD_INTER_PART_DELAY_MS=1000

# DISCORD_LOGGING_ENABLED: Enable logging to files
# Optional. Default: false
# DISCORD_LOGGING_ENABLED=false

# DISCORD_MAX_MESSAGE_LENGTH: Max message length
# Optional. Default: 2000
# DISCORD_MAX_MESSAGE_LENGTH=2000

# DISCORD_MESSAGE_PROCESSING_DELAY_MS: Delay for processing messages (ms)
# Optional. Default: 0
# DISCORD_MESSAGE_PROCESSING_DELAY_MS=0

# DISCORD_PRIORITY_CHANNEL: Priority channel ID
# Optional. Default:
# DISCORD_PRIORITY_CHANNEL=

# DISCORD_PRIORITY_CHANNEL_BONUS: Bonus chance for priority channel
# Optional. Default: 1.1
# DISCORD_PRIORITY_CHANNEL_BONUS=1.1

# DISCORD_TYPING_DELAY_MAX_MS: Max typing delay (ms)
# Optional. Default: 5000
# DISCORD_TYPING_DELAY_MAX_MS=5000

# DISCORD_UNSOLICITED_CHANCE_MODIFIER: Global unsolicited chance modifier
# Optional. Default: 1.0
# DISCORD_UNSOLICITED_CHANCE_MODIFIER=1.0

# DISCORD_WELCOME_MESSAGE: Welcome message for new users
# Optional. Default: Welcome to the server!
# DISCORD_WELCOME_MESSAGE=Welcome to the server!

# FLOWISE_API_ENDPOINT: API endpoint for Flowise
# Optional. Default:
# FLOWISE_API_ENDPOINT=

# FLOWISE_USE_REST: No description provided
# Optional. Default: true
# FLOWISE_USE_REST=true

# GREETING: No description provided
# Optional. Default:
# GREETING=

# LLM_PARALLEL_EXECUTION: Whether to allow parallel execution of requests
# Optional. Default: false
# LLM_PARALLEL_EXECUTION=false

# LLM_TASK_FOLLOWUP_MODEL: Override model for follow-up generation tasks (provider-specific)
# Optional. Default:
# LLM_TASK_FOLLOWUP_MODEL=

# LLM_TASK_FOLLOWUP_PROVIDER: Override provider for follow-up generation tasks (id | name | type)
# Optional. Default:
# LLM_TASK_FOLLOWUP_PROVIDER=

# LLM_TASK_IDLE_MODEL: Override model for idle-response generation tasks (provider-specific)
# Optional. Default:
# LLM_TASK_IDLE_MODEL=

# LLM_TASK_IDLE_PROVIDER: Override provider for idle-response generation tasks (id | name | type)
# Optional. Default:
# LLM_TASK_IDLE_PROVIDER=

# LLM_TASK_SEMANTIC_MODEL: Override model for semantic relevance checks (provider-specific)
# Optional. Default:
# LLM_TASK_SEMANTIC_MODEL=

# LLM_TASK_SEMANTIC_PROVIDER: Override provider for semantic relevance checks (id | name | type)
# Optional. Default:
# LLM_TASK_SEMANTIC_PROVIDER=

# LLM_TASK_SUMMARY_MODEL: Override model for summarization tasks (provider-specific)
# Optional. Default:
# LLM_TASK_SUMMARY_MODEL=

# LLM_TASK_SUMMARY_PROVIDER: Override provider for summarization tasks (id | name | type)
# Optional. Default:
# LLM_TASK_SUMMARY_PROVIDER=

# MATTERMOST_CHANNEL: Default Mattermost channel for messages
# Optional. Default:
# MATTERMOST_CHANNEL=

# MESSAGE_ADD_USER_HINT: Whether to add user hint to messages
# Optional. Default: true
# MESSAGE_ADD_USER_HINT=true

# MESSAGE_ALLOW_BOT_TO_BOT_UNADDRESSED: Allow replying to bot-authored messages even when not explicitly addressed (risk: bot loops); addressed replies still work regardless
# Optional. Default: false
# MESSAGE_ALLOW_BOT_TO_BOT_UNADDRESSED=false

# MESSAGE_ALLOW_SELF_MENTION: Allow bot to @mention itself in responses (default: false, strips self-mentions)
# Optional. Default: false
# MESSAGE_ALLOW_SELF_MENTION=false

# MESSAGE_BOT_REPLIES_LIMIT_TO_DEFAULT_CHANNEL: When responding to bots, limit responses to the default channel only (prevents spam in other channels)
# Optional. Default: false
# MESSAGE_BOT_REPLIES_LIMIT_TO_DEFAULT_CHANNEL=false

# MESSAGE_CALM_WINDOW: Calm window for message processing (ms)
# Optional. Default: 300000
# MESSAGE_CALM_WINDOW=300000

# MESSAGE_CHANNEL_ROUTER_ENABLED: Enable ChannelRouter-based outbound channel selection
# Optional. Default: false
# MESSAGE_CHANNEL_ROUTER_ENABLED=false

# MESSAGE_COMMAND_AUTHORISED_USERS: Comma-separated list of authorised users for commands
# Optional. Default:
# MESSAGE_COMMAND_AUTHORISED_USERS=

# MESSAGE_COMMAND_INLINE: Enable inline command processing
# Optional. Default: true
# MESSAGE_COMMAND_INLINE=true

# MESSAGE_COMMAND_SLASH: Enable slash command processing
# Optional. Default: true
# MESSAGE_COMMAND_SLASH=true

# MESSAGE_COMPOUNDING_DELAY_BASE_MS: Base delay per message for compounding delay (ms). New messages during pre-typing extend this delay.
# Optional. Default: 1500
# MESSAGE_COMPOUNDING_DELAY_BASE_MS=1500

# MESSAGE_COMPOUNDING_DELAY_MAX_MS: Maximum compounding delay before responding (ms). Prevents infinite wait.
# Optional. Default: 15000
# MESSAGE_COMPOUNDING_DELAY_MAX_MS=15000

# MESSAGE_DECAY_RATE: Decay rate for message processing
# Optional. Default: 0.001
# MESSAGE_DECAY_RATE=0.001

# MESSAGE_DELAY_MULTIPLIER: Multiplier applied to artificial delays (pre-inference, line delays, scheduler delays)
# Optional. Default: 1
# MESSAGE_DELAY_MULTIPLIER=1

# MESSAGE_DUPLICATE_HISTORY_SIZE: Number of recent messages to track for duplicate detection
# Optional. Default: 10
# MESSAGE_DUPLICATE_HISTORY_SIZE=10

# MESSAGE_DUPLICATE_WINDOW_MS: Time window in milliseconds to check for duplicate messages (default: 5 minutes)
# Optional. Default: 300000
# MESSAGE_DUPLICATE_WINDOW_MS=300000

# MESSAGE_FILTER_BY_USER: Filter messages by user
# Optional. Default:
# MESSAGE_FILTER_BY_USER=

# MESSAGE_FOLLOW_UP_ENABLED: Enable message follow-up functionality
# Optional. Default: true
# MESSAGE_FOLLOW_UP_ENABLED=true

# MESSAGE_HISTORY_ADAPTIVE_ENABLED: Enable adaptive history fetch sizing (per-channel)
# Optional. Default: true
# MESSAGE_HISTORY_ADAPTIVE_ENABLED=true

# MESSAGE_HISTORY_ADAPTIVE_MAX_LIMIT: Maximum history fetch limit when adaptive sizing is enabled
# Optional. Default: 60
# MESSAGE_HISTORY_ADAPTIVE_MAX_LIMIT=60

# MESSAGE_HISTORY_ADAPTIVE_MIN_LIMIT: Minimum history fetch limit when adaptive sizing is enabled
# Optional. Default: 6
# MESSAGE_HISTORY_ADAPTIVE_MIN_LIMIT=6

# MESSAGE_HISTORY_ADAPTIVE_STEP: Step size for adaptive history fetch sizing
# Optional. Default: 5
# MESSAGE_HISTORY_ADAPTIVE_STEP=5

# MESSAGE_HISTORY_ADAPTIVE_TARGET_UTILIZATION: Target input token budget utilization for adaptive history sizing (0-1)
# Optional. Default: 0.75
# MESSAGE_HISTORY_ADAPTIVE_TARGET_UTILIZATION=0.75

# MESSAGE_HISTORY_LIMIT: Limit for message history
# Optional. Default: 30
# MESSAGE_HISTORY_LIMIT=30

# MESSAGE_IGNORE_BOTS: Whether to ignore messages from bots entirely
# Optional. Default: false
# MESSAGE_IGNORE_BOTS=false

# MESSAGE_INTERACTIVE_FOLLOWUPS: Allow interactive follow-up questions
# Optional. Default: false
# MESSAGE_INTERACTIVE_FOLLOWUPS=false

# MESSAGE_LLM_CHAT: Enable LLM chat functionality
# Optional. Default: true
# MESSAGE_LLM_CHAT=true

# MESSAGE_LLM_COMPLETE_SENTENCE: Enable LLM sentence completion
# Optional. Default: true
# MESSAGE_LLM_COMPLETE_SENTENCE=true

# MESSAGE_LLM_CONTEXT_SAFETY_MARGIN_TOKENS: Safety margin reserved from the context window for hidden/system overhead
# Optional. Default: 400
# MESSAGE_LLM_CONTEXT_SAFETY_MARGIN_TOKENS=400

# MESSAGE_LLM_CONTEXT_WINDOW_TOKENS: Approximate model context window (input+output) used for token-budgeted history trimming
# Optional. Default: 8000
# MESSAGE_LLM_CONTEXT_WINDOW_TOKENS=8000

# MESSAGE_LLM_FOLLOW_UP: Enable LLM follow-up responses
# Optional. Default: false
# MESSAGE_LLM_FOLLOW_UP=false

# MESSAGE_LLM_SUMMARISE: Enable LLM summarization
# Optional. Default: false
# MESSAGE_LLM_SUMMARISE=false

# MESSAGE_MAX_DELAY: Maximum delay between messages (ms)
# Optional. Default: 10000
# MESSAGE_MAX_DELAY=10000

# MESSAGE_MAX_GENERATION_RETRIES: Maximum number of retries for bad generation / duplicates / nonsense
# Optional. Default: 3
# MESSAGE_MAX_GENERATION_RETRIES=3

# MESSAGE_MIN_DELAY: Minimum delay between messages (ms)
# Optional. Default: 1000
# MESSAGE_MIN_DELAY=1000

# MESSAGE_MIN_INTERVAL_MS: Minimum interval between messages (ms)
# Optional. Default: 3000
# MESSAGE_MIN_INTERVAL_MS=3000

# MESSAGE_ONLY_WHEN_SPOKEN_TO: Only respond when spoken to directly
# Optional. Default: true
# MESSAGE_ONLY_WHEN_SPOKEN_TO=true

# MESSAGE_ONLY_WHEN_SPOKEN_TO_GRACE_WINDOW_MS: When MESSAGE_ONLY_WHEN_SPOKEN_TO=true, allow unaddressed replies if the bot has spoken in this channel within this window (ms); set 0 to disable
# Optional. Default: 300000
# MESSAGE_ONLY_WHEN_SPOKEN_TO_GRACE_WINDOW_MS=300000

# MESSAGE_OTHERS_TYPING_MAX_WAIT_MS: Max additional wait before starting typing even if others keep typing (ms)
# Optional. Default: 5000
# MESSAGE_OTHERS_TYPING_MAX_WAIT_MS=5000

# MESSAGE_OTHERS_TYPING_WINDOW_MS: Window to consider other users as currently typing (ms)
# Optional. Default: 8000
# Optional. Default: 8000
# MESSAGE_OTHERS_TYPING_WINDOW_MS=8000

# MESSAGE_RATE_LIMIT_PER_CHANNEL: Rate limit per channel (messages per minute)
# Optional. Default: 5
# MESSAGE_RATE_LIMIT_PER_CHANNEL=5

# MESSAGE_READING_DELAY_BASE_MS: Base pre-typing/pre-inference reading delay (ms)
# Optional. Default: 200
# Optional. Default: 200
# MESSAGE_READING_DELAY_BASE_MS=200

# MESSAGE_READING_DELAY_MAX_MS: Maximum pre-typing/pre-inference reading delay (ms)
# Optional. Default: 2000
# MESSAGE_READING_DELAY_MAX_MS=2000

# MESSAGE_READING_DELAY_MIN_MS: Minimum pre-typing/pre-inference reading delay (ms)
# Optional. Default: 500
# MESSAGE_READING_DELAY_MIN_MS=500

# MESSAGE_READING_DELAY_PER_CHAR_MS: Per-character component for pre-typing/pre-inference reading delay (ms)
# Optional. Default: 15
# MESSAGE_READING_DELAY_PER_CHAR_MS=15

# MESSAGE_RESPOND_IN_THREAD: Respond in thread when possible
# Optional. Default: false
# MESSAGE_RESPOND_IN_THREAD=false

# MESSAGE_RESPONSE_PROFILES: No description provided
# Optional. Default:
# MESSAGE_RESPONSE_PROFILES=

# MESSAGE_SEMANTIC_RELEVANCE_BONUS: Multiplier to apply when message is semantically relevant and bot has posted recently (default: 10x)
# Optional. Default: 10
# MESSAGE_SEMANTIC_RELEVANCE_BONUS=10

# MESSAGE_SEMANTIC_RELEVANCE_ENABLED: Enable semantic relevance check - uses 1-token LLM call to boost reply chance if message is on-topic
# Optional. Default: true
# MESSAGE_SEMANTIC_RELEVANCE_ENABLED=true

# MESSAGE_SEND_ANYWAY_ON_BAD_GENERATION: If true, send the message even if it fails coherence/nonsense checks after retries (prevents blocking on false positives)
# Optional. Default: true
# MESSAGE_SEND_ANYWAY_ON_BAD_GENERATION=true

# MESSAGE_SHORT_LENGTH_PENALTY: Penalty to apply to probability for very short messages (<10 chars) to discourage responding to single words
# Optional. Default: 0.1
# Optional. Default: 0.1
# MESSAGE_SHORT_LENGTH_PENALTY=0.1

# MESSAGE_STRIP_BOT_ID: Strip bot ID from messages
# Optional. Default: true
# MESSAGE_STRIP_BOT_ID=true

# MESSAGE_SUPPRESS_DUPLICATES: Suppress duplicate/repetitive bot responses (enabled by default)
# Optional. Default: true
# MESSAGE_SUPPRESS_DUPLICATES=true

# MESSAGE_TEMPERATURE_REPETITION_MAX_BOOST: Max temperature boost applied when the bot is repeating the same words across recent responses
# Optional. Default: 0.4
# MESSAGE_TEMPERATURE_REPETITION_MAX_BOOST=0.4

# MESSAGE_TEMPERATURE_REPETITION_MIN_DOC_FREQ: Minimum number of distinct recent bot messages a word must appear in to be considered overused
# Optional. Default: 3
# MESSAGE_TEMPERATURE_REPETITION_MIN_DOC_FREQ=3

# MESSAGE_TEMPERATURE_REPETITION_MIN_HISTORY: Minimum number of recent bot messages required before repetition-based temperature boosting is applied
# Optional. Default: 3
# MESSAGE_TEMPERATURE_REPETITION_MIN_HISTORY=3

# MESSAGE_TEMPERATURE_REPETITION_RATIO_THRESHOLD: Doc-frequency ratio threshold (0-1) for a word to be considered overused (e.g., 0.6 means in >=60% of recent bot messages)
# Optional. Default: 0.6
# MESSAGE_TEMPERATURE_REPETITION_RATIO_THRESHOLD=0.6

# MESSAGE_THREAD_RELATION_WINDOW: Time window to consider messages related to a thread (ms)
# Optional. Default: 300000
# MESSAGE_THREAD_RELATION_WINDOW=300000

# MESSAGE_UNSOLICITED_ADDRESSED: Allow unsolicited addressed messages
# Optional. Default: false
# MESSAGE_UNSOLICITED_ADDRESSED=false

# MESSAGE_UNSOLICITED_BASE_CHANCE: Base probability for replying when not explicitly addressed (only used when MESSAGE_ONLY_WHEN_SPOKEN_TO=false)
# Optional. Default: 0.01
# MESSAGE_UNSOLICITED_BASE_CHANCE=0.01

# MESSAGE_UNSOLICITED_SILENCE_PARTICIPANT_MAX_FACTOR: Maximum multiplier applied to silent-chance based on participant count
# Optional. Default: 3
# MESSAGE_UNSOLICITED_SILENCE_PARTICIPANT_MAX_FACTOR=3

# MESSAGE_UNSOLICITED_SILENCE_PARTICIPANT_MIN_FACTOR: Minimum multiplier applied to silent-chance based on participant count
# Optional. Default: 0.25
# MESSAGE_UNSOLICITED_SILENCE_PARTICIPANT_MIN_FACTOR=0.25

# MESSAGE_UNSOLICITED_SILENCE_PARTICIPANT_REFERENCE: Participant reference point (factor=reference/participants) when the bot has been silent
# Optional. Default: 2
# MESSAGE_UNSOLICITED_SILENCE_PARTICIPANT_REFERENCE=2

# MESSAGE_UNSOLICITED_SILENCE_PARTICIPANT_WINDOW_MS: Window for counting unique participants when the bot has been silent (ms)
# Optional. Default: 300000
# MESSAGE_UNSOLICITED_SILENCE_PARTICIPANT_WINDOW_MS=300000

# MESSAGE_UNSOLICITED_UNADDRESSED: Allow unsolicited unaddressed messages
# Optional. Default: false
# MESSAGE_UNSOLICITED_UNADDRESSED=false

# MESSAGE_WEBHOOK_ENABLED: Enable webhook functionality
# Optional. Default: true
# MESSAGE_WEBHOOK_ENABLED=true

# NAME: Application name
# Optional. Default: Open-Hivemind
# NAME=Open-Hivemind

# OPENAI_EMBEDDING_MODELS: Supported OpenAI embedding models for provider configuration
# OPENAI_EMBEDDING_MODELS=['text-embedding-3-large', 'text-embedding-3-small', 'text-embedding-ada-002']

# OPENAI_FINISH_REASON_RETRY: Retry strategy based on finish reason
# Optional. Default: stop
# OPENAI_FINISH_REASON_RETRY=stop

# OPENAI_FREQUENCY_PENALTY: Frequency penalty for OpenAI
# Optional. Default: 0.1
# OPENAI_FREQUENCY_PENALTY=0.1

# OPENAI_MAX_RETRIES: Maximum number of retries for OpenAI requests
# Optional. Default: 3
# OPENAI_MAX_RETRIES=3

# OPENAI_ORGANIZATION: OpenAI organization ID
# Optional. Default:
# OPENAI_ORGANIZATION=

# OPENAI_PRESENCE_PENALTY: Presence penalty for OpenAI
# Optional. Default: 0.05
# OPENAI_PRESENCE_PENALTY=0.05

# OPENAI_RESPONSE_MAX_TOKENS: Max tokens for OpenAI response
# Optional. Default: 100
# OPENAI_RESPONSE_MAX_TOKENS=100

# OPENAI_STOP: Stop sequences for OpenAI
# Optional. Default: []
# OPENAI_STOP=[]

# OPENAI_TEMPERATURE: Sampling temperature for OpenAI
# Optional. Default: 0.7
# OPENAI_TEMPERATURE=0.7

# OPENAI_TIMEOUT: API request timeout for OpenAI (ms)
# Optional. Default: 10000
# OPENAI_TIMEOUT=10000

# OPENAI_TOP_P: Top-p sampling for OpenAI
# Optional. Default: 1.0
# OPENAI_TOP_P=1.0

# OPENAI_VOICE: OpenAI Voice for TTS
# Optional. Default: nova
# OPENAI_VOICE=nova

# OPEN_WEBUI_API_URL: Open WebUI API URL
# Optional. Default: http://host.docker.internal:3000/api/
# OPEN_WEBUI_API_URL=http://host.docker.internal:3000/api/

# OPEN_WEBUI_KNOWLEDGE_FILE: Path to Open WebUI knowledge file
# Optional. Default:
# OPEN_WEBUI_KNOWLEDGE_FILE=

# OPEN_WEBUI_PASSWORD: Open WebUI password - MUST be set via environment variable
# Optional. Default: password123
# OPEN_WEBUI_PASSWORD=password123

# OPEN_WEBUI_USERNAME: Open WebUI username
# Optional. Default: admin
# OPEN_WEBUI_USERNAME=admin

# PLATFORM: Platform identifier
# Optional. Default: discord
# PLATFORM=discord

# PLAYWRIGHT_BASE_URL: No description provided
# Optional. Default: http://localhost:3000
# PLAYWRIGHT_BASE_URL=http://localhost:3000

# REPORT_ISSUE_URL: URL for reporting issues with the bot
# Optional. Default: https://university.example.com/report-issue
# REPORT_ISSUE_URL=https://university.example.com/report-issue

# SLACK_BOT_JOIN_CHANNEL_MESSAGE: No description provided
# Optional. Default:
# SLACK_BOT_JOIN_CHANNEL_MESSAGE=

# SLACK_BOT_LEARN_MORE_MESSAGE: No description provided
# Optional. Default:
# SLACK_BOT_LEARN_MORE_MESSAGE=

# SLACK_BUTTON_MAPPINGS: No description provided
# Optional. Default:
# SLACK_BUTTON_MAPPINGS=

# SLACK_JOIN_CHANNELS: Comma-separated channel IDs to join
# Optional. Default:
# SLACK_JOIN_CHANNELS=

# SLACK_MODE: Slack connection mode (socket or rtm)
# Optional. Default: socket
# SLACK_MODE=socket

# SLACK_USER_JOIN_CHANNEL_MESSAGE: No description provided
# Optional. Default:
# SLACK_USER_JOIN_CHANNEL_MESSAGE=

# TELEGRAM_ALLOWED_CHATS: Comma-separated list of chat IDs the bot can respond in (leave empty for all)
# Optional. Default:
# TELEGRAM_ALLOWED_CHATS=

# TELEGRAM_BLOCKED_USERS: Comma-separated list of user IDs the bot cannot respond to
# Optional. Default:
# TELEGRAM_BLOCKED_USERS=

# TELEGRAM_ENABLE_COMMANDS: Enable bot commands (/start, /help, etc.)
# Optional. Default: true
# TELEGRAM_ENABLE_COMMANDS=true

# TELEGRAM_PARSE_MODE: Format for message parsing (HTML, Markdown, None)
# Optional. Default: HTML
# TELEGRAM_PARSE_MODE=HTML

# TELEGRAM_WEBHOOK_URL: URL for receiving updates (leave empty for polling)
# Optional. Default:
# TELEGRAM_WEBHOOK_URL=

# WEBHOOK_TOKEN: Token used to verify incoming webhook requests
# Optional. Default:
# WEBHOOK_TOKEN=

# WEBHOOK_URL: Webhook URL for sending messages
# Optional. Default:
# WEBHOOK_URL=