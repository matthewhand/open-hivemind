# ==============================================================================
# Open-Hivemind - Environment Configuration (.env)
# ==============================================================================
# This file provides an example setup for configuring your AI agents.
# All available environment variables with their descriptions, required status,
# and example formats are listed below.
# ==============================================================================

# ------------------------------------------------------------------------------
# System & General Server Configuration
# ------------------------------------------------------------------------------

# NODE_ENV: The environment mode (development, production, test).
# Optional. Default: development
NODE_ENV=development

# PORT: The port number the main server listens on.
# Optional. Default: 3000
PORT=3000

# BASE_URL: The base URL of the deployment (used for links and webhooks).
# Optional. Default: http://localhost:3000
BASE_URL=http://localhost:3000

# LOG_LEVEL: Standard logging level (error, warn, info, debug, trace).
# Optional. Default: info
LOG_LEVEL=info

# ERROR_LOG_PATH: File path for logging errors.
# Optional. Default: ./logs/error.log
# ERROR_LOG_PATH=./logs/error.log

# NODE_CONFIG_DIR: Override directory for static configuration files.
# Optional. Default: ./config
# NODE_CONFIG_DIR=./config

# DEBUG: Show extended diagnostic debug info (e.g. app:*, express:*).
# Optional. Default: (none)
# DEBUG=app:*

# DEMO_MODE: Enable restricted demonstration mode (blocks structural edits).
# Optional. Default: false
DEMO_MODE=false

# ------------------------------------------------------------------------------
# Security & Authentication
# ------------------------------------------------------------------------------

# ADMIN_PASSWORD: Set an admin password for initial login.
# Required in production. Example: your-secure-admin-password
ADMIN_PASSWORD=your-secure-admin-password

# SESSION_SECRET: Cryptographic key used to encrypt stateful user sessions.
# Required in production. Example: your-secure-session-secret
SESSION_SECRET=your-secure-session-secret

# JWT_SECRET: Secret for signing JWT access tokens.
# Required in production. Example: your-jwt-access-secret
JWT_SECRET=your-jwt-access-secret

# JWT_REFRESH_SECRET: Secret for signing JWT refresh tokens.
# Required in production. Example: your-jwt-refresh-secret
JWT_REFRESH_SECRET=your-jwt-refresh-secret

# API_AUTH_TOKEN: Static token for authenticating programmatic API requests.
# Optional. Example: your-api-auth-token
API_AUTH_TOKEN=your-api-auth-token

# ADMIN_IP_WHITELIST: Comma-separated list of IPs allowed to bypass or access admin panel.
# Optional. Default: 127.0.0.1
ADMIN_IP_WHITELIST=127.0.0.1

# ALLOW_LOCALHOST_ADMIN: Allow localhost access to admin panel.
# Optional. Default: true
ALLOW_LOCALHOST_ADMIN=true

# ALLOW_LOCAL_NETWORK_ACCESS: Allow local network access to admin panel.
# Optional. Default: false
ALLOW_LOCAL_NETWORK_ACCESS=false

# CORS_ORIGIN: CORS origin allowed to access the API.
# Optional. Default: *
CORS_ORIGIN=*

# TRUST_PROXY: Proxy trust setting for Express behind load balancers.
# Optional. Default: false
TRUST_PROXY=false

# TRUSTED_PROXIES: Comma-separated list of trusted proxies.
# Optional. Default: (none)
# TRUSTED_PROXIES=

# SESSION_COOKIE_NAME: Custom name for the session cookie.
# Optional. Example: hivemind.sid
# SESSION_COOKIE_NAME=hivemind.sid

# CSRF_SKIP_IN_TEST: Skip CSRF token validation when running in tests.
# Optional. Default: false
# CSRF_SKIP_IN_TEST=false

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------

# REDIS_URL: Redis connection string used for caching, sessions, and rate limit stores.
# Optional. Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# RATE_LIMIT_MAX: Max requests per window overall.
# Optional. Default: 100
# RATE_LIMIT_MAX=100

# RATE_LIMIT_WINDOW_MS: Window size in milliseconds for generic rate limit.
# Optional. Default: 60000
# RATE_LIMIT_WINDOW_MS=60000

# RATE_LIMIT_API_MAX: Max requests per window for the API endpoints.
# Optional. Default: 100
RATE_LIMIT_API_MAX=100

# RATE_LIMIT_API_WINDOW_MS: Window size in ms for API endpoints rate limit.
# Optional. Default: 60000 (1 minute)
RATE_LIMIT_API_WINDOW_MS=60000

# RATE_LIMIT_AUTH_MAX: Max requests per window for Authentication endpoints.
# Optional. Default: 5
RATE_LIMIT_AUTH_MAX=5

# RATE_LIMIT_AUTH_WINDOW_MS: Window size in ms for Auth rate limit.
# Optional. Default: 300000 (5 minutes)
RATE_LIMIT_AUTH_WINDOW_MS=300000

# RATE_LIMIT_ADMIN_MAX: Max requests for Admin specific endpoints.
# Optional. Default: 100
# RATE_LIMIT_ADMIN_MAX=100

# RATE_LIMIT_ADMIN_WINDOW_MS: Admin endpoints window size in ms.
# Optional. Default: 60000
# RATE_LIMIT_ADMIN_WINDOW_MS=60000

# DISABLE_RATE_LIMIT: Completely disable all rate limiting logic.
# Optional. Default: false
DISABLE_RATE_LIMIT=false

# ------------------------------------------------------------------------------
# Multi-Bot Configuration (Prefix: BOTS_<BOT_NAME>_)
# ------------------------------------------------------------------------------
# NEW MULTI-BOT CAPABILITY:
# You can now run multiple bots simultaneously across different platforms and LLMs.
# To configure a specific bot, prefix its configuration keys with: BOTS_<BOT_NAME>_
#
# Supported Message Providers: discord, slack, mattermost, webhook
# Supported LLM Providers: openai, flowise, openwebui, perplexity, replicate, n8n, openswarm

# Example Bot 1: "Alpha" (Discord + OpenAI)
# Optional.
BOTS_ALPHA_MESSAGE_PROVIDER=discord
BOTS_ALPHA_LLM_PROVIDER=openai
BOTS_ALPHA_PERSONA=default
BOTS_ALPHA_DISCORD_BOT_TOKEN=your-discord-bot-token-here
BOTS_ALPHA_DISCORD_CLIENT_ID=your-discord-client-id
BOTS_ALPHA_DISCORD_GUILD_ID=your-discord-guild-id
BOTS_ALPHA_DISCORD_CHANNEL_ID=your-default-channel-id
BOTS_ALPHA_OPENAI_API_KEY=sk-your-openai-api-key
BOTS_ALPHA_OPENAI_MODEL=gpt-4o
BOTS_ALPHA_OPENAI_BASE_URL=https://api.openai.com/v1/
BOTS_ALPHA_OPENAI_SYSTEM_PROMPT="You are Alpha, a helpful Discord assistant."

# Example Bot 2: "Beta" (Slack + Flowise)
# Optional.
BOTS_BETA_MESSAGE_PROVIDER=slack
BOTS_BETA_LLM_PROVIDER=flowise
BOTS_BETA_PERSONA=tech_support
BOTS_BETA_SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
BOTS_BETA_SLACK_APP_TOKEN=xapp-your-slack-app-token
BOTS_BETA_SLACK_SIGNING_SECRET=your-slack-signing-secret
BOTS_BETA_FLOWISE_API_BASE_URL=http://localhost:3000/api/v1
BOTS_BETA_FLOWISE_API_KEY=your-flowise-api-key

# ------------------------------------------------------------------------------
# Legacy / Global Configuration (Optional)
# ------------------------------------------------------------------------------
# If you only intend to run a single bot and do not want to use the BOTS_<NAME>_
# prefix, you can use these global fallbacks.

# MESSAGE_PROVIDER: Default message provider if no bot-specific one is set.
# Optional. Default: discord
MESSAGE_PROVIDER=discord

# MESSAGE_USERNAME_OVERRIDE: Override name for the bot's messages.
# Optional. Example: OpenHivemind
# MESSAGE_USERNAME_OVERRIDE=OpenHivemind

# --- Discord ---
# DISCORD_BOT_TOKEN: Global fallback Discord bot token.
# Optional (but required if Discord is primary). Example: your-discord-token
DISCORD_BOT_TOKEN=your-discord-token

# DISCORD_CLIENT_ID: Discord OAuth Client ID.
# Optional. Example: your-discord-client-id
# DISCORD_CLIENT_ID=your-discord-client-id

# DISCORD_GUILD_ID: Target Discord Guild (Server) ID.
# Optional. Example: your-discord-guild-id
# DISCORD_GUILD_ID=your-discord-guild-id

# DISCORD_CHANNEL_ID: Default Discord text channel for system broadcasts.
# Optional. Example: your-default-channel-id
# DISCORD_CHANNEL_ID=your-default-channel-id

# DISCORD_VOICE_CHANNEL_ID: Target voice channel for audio extensions.
# Optional. Example: your-voice-channel-id
# DISCORD_VOICE_CHANNEL_ID=

# DISCORD_MESSAGE_HISTORY_LIMIT: Cap fetched history limits.
# Optional. Default: 10
# DISCORD_MESSAGE_HISTORY_LIMIT=10

# --- Slack ---
# SLACK_BOT_TOKEN: Slack bot token (starts with xoxb-).
# Optional (but required if Slack is primary). Example: xoxb-your-slack-bot-token
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# SLACK_APP_TOKEN: Slack app-level token (starts with xapp-) for Socket mode.
# Optional. Example: xapp-your-slack-app-token
# SLACK_APP_TOKEN=xapp-your-slack-app-token

# SLACK_SIGNING_SECRET: Slack signing secret for request validation.
# Optional. Example: your-slack-signing-secret
# SLACK_SIGNING_SECRET=your-slack-signing-secret

# SLACK_DEFAULT_CHANNEL_ID: Default Slack text channel.
# Optional. Example: C12345678
# SLACK_DEFAULT_CHANNEL_ID=

# --- Mattermost ---
# MATTERMOST_SERVER_URL: Base URL of Mattermost server.
# Optional. Example: https://mattermost.example.com
# MATTERMOST_SERVER_URL=https://mattermost.example.com

# MATTERMOST_TOKEN: Mattermost bot access token.
# Optional (but required if Mattermost is primary). Example: your-mattermost-bot-token
# MATTERMOST_TOKEN=your-mattermost-bot-token

# --- Telegram ---
# TELEGRAM_BOT_TOKEN: Telegram bot access token.
# Optional. Example: your-telegram-token
# TELEGRAM_BOT_TOKEN=your-telegram-token

# --- Webhook (Custom Integrations) ---
# WEBHOOK_ENABLED: Enables inbound webhook listeners.
# Optional. Default: false
# WEBHOOK_ENABLED=false

# WEBHOOK_PORT: Port specifically for webhook endpoints if separate.
# Optional. Example: 3001
# WEBHOOK_PORT=

# WEBHOOK_IP_WHITELIST: Comma-separated list of IPs allowed to call webhook endpoints.
# ⚠️ BREAKING CHANGE: An empty value now BLOCKS all requests (default-deny).
# Previously an empty value allowed all IPs. To restore open access use: 0.0.0.0/0
# Supports exact IPv4 and IPv6 addresses. CIDR notation is NOT currently supported.
# Example (restrict to two IPs): WEBHOOK_IP_WHITELIST=203.0.113.10,203.0.113.11
# Example (loopback only):       WEBHOOK_IP_WHITELIST=127.0.0.1,::1,::ffff:127.0.0.1
# WEBHOOK_IP_WHITELIST=

# ------------------------------------------------------------------------------
# Global LLM Providers Configs
# ------------------------------------------------------------------------------

# LLM_PROVIDER: Default LLM provider (openai, flowise, openwebui, perplexity, replicate, n8n, openswarm, ollama).
# Optional. Default: openai
LLM_PROVIDER=openai

# --- OpenAI ---
# OPENAI_API_KEY: Default OpenAI API key.
# Optional (required if LLM_PROVIDER is openai). Example: sk-your-openai-api-key
OPENAI_API_KEY=your-openai-api-key

# OPENAI_BASE_URL: Default OpenAI API base URL (can be customized for compatible APIs like vLLM).
# Optional. Default: https://api.openai.com/v1/
OPENAI_BASE_URL=https://api.openai.com/v1/

# OPENAI_MODEL: Default OpenAI model.
# Optional. Default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# OPENAI_SYSTEM_PROMPT: Global system prompt for OpenAI.
# Optional. Example: You are a helpful AI assistant.
# OPENAI_SYSTEM_PROMPT="You are a helpful AI assistant."

# OPENAI_MAX_TOKENS: Generation max token limit.
# Optional. Example: 4096
# OPENAI_MAX_TOKENS=

# --- Flowise ---
# FLOWISE_API_BASE_URL: Base API URL for Flowise instance.
# Optional. Default: http://localhost:3000/api/v1
FLOWISE_API_BASE_URL=http://localhost:3000/api/v1

# FLOWISE_API_KEY: Flowise API key.
# Optional. Example: your-flowise-api-key
FLOWISE_API_KEY=your-flowise-api-key

# FLOWISE_CONVERSATION_CHATFLOW_ID: Default conversational chatflow ID.
# Optional. Example: your-conversation-chatflow-id
# FLOWISE_CONVERSATION_CHATFLOW_ID=

# FLOWISE_COMPLETION_CHATFLOW_ID: Default completion chatflow ID.
# Optional. Example: your-completion-chatflow-id
# FLOWISE_COMPLETION_CHATFLOW_ID=

# --- OpenWebUI ---
# OPENWEBUI_API_URL: Base API URL for OpenWebUI instance.
# Optional. Example: http://localhost:8080/api/v1
# OPENWEBUI_API_URL=http://localhost:8080/api/v1

# OPENWEBUI_API_KEY: API Key for OpenWebUI.
# Optional. Example: your-openwebui-api-key
# OPENWEBUI_API_KEY=your-openwebui-api-key

# OPEN_WEBUI_MODEL: Target model for OpenWebUI requests.
# Optional. Example: llama3
# OPEN_WEBUI_MODEL=

# --- Ollama ---
# OLLAMA_BASE_URL: Target url for standard local Ollama deployment.
# Optional. Example: http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434

# OLLAMA_MODEL: Target model running on local Ollama.
# Optional. Example: llama3.1
# OLLAMA_MODEL=llama3.1

# --- Replicate ---
# REPLICATE_API_TOKEN: API token for the Replicate platform.
# Optional. Example: your-replicate-api-token
# REPLICATE_API_TOKEN=your-replicate-api-token

# REPLICATE_MODEL_VERSION: Specific image generation or text generation version hash.
# Optional. Example: your-replicate-model-version
# REPLICATE_MODEL_VERSION=your-replicate-model-version

# REPLICATE_WEBHOOK_URL: Webhook URL Replicate should POST updates to.
# Optional. Example: http://your-domain.com/replicate/webhook
# REPLICATE_WEBHOOK_URL=

# --- OpenSwarm ---
# OPENSWARM_API_KEY: Swarm API authentication key.
# Optional. Example: your-openswarm-api-key
# OPENSWARM_API_KEY=

# OPENSWARM_BASE_URL: Target URL for swarm operations.
# Optional. Example: http://localhost:8000/v1
# OPENSWARM_BASE_URL=http://localhost:8000/v1

# OPENSWARM_TEAM: Multi-agent logical team name.
# Optional. Example: default-team
# OPENSWARM_TEAM=default-team

# --- Memory providers ---
# Open-Hivemind supports multiple memory providers with different embedding strategies.
# All providers support custom OpenAI-compatible embedding endpoints.

# === Mem0 (Local SDK with fact extraction) ===
# Mem0 uses LLM for automatic fact extraction + embeddings for vector search.
# Requires: OpenAI API key (or compatible endpoint)

# MEM0_API_KEY: OpenAI API key for LLM fact extraction and embeddings.
# Optional. Example: sk-your-openai-api-key
# MEM0_API_KEY=your-openai-api-key

# MEM0_LLM_PROVIDER: LLM provider for fact extraction (openai, anthropic).
# Optional. Default: openai
# MEM0_LLM_PROVIDER=openai

# MEM0_LLM_MODEL: Model for fact extraction.
# Optional. Default: gpt-4o-mini
# MEM0_LLM_MODEL=gpt-4o-mini

# MEM0_LLM_BASE_URL: Custom LLM endpoint (for vLLM, Ollama, etc.).
# Optional. Example: http://localhost:8000/v1
# MEM0_LLM_BASE_URL=http://localhost:8000/v1

# MEM0_EMBEDDER_MODEL: Embedding model name.
# Optional. Default: text-embedding-3-small
# MEM0_EMBEDDER_MODEL=text-embedding-3-small

# MEM0_EMBEDDER_BASE_URL: Custom embedding endpoint (OpenAI-compatible).
# Use this to point to vLLM, Ollama, Voyage, or any OpenAI-compatible embedding server.
# Optional. Example: http://localhost:8000/v1
# MEM0_EMBEDDER_BASE_URL=http://localhost:8000/v1

# MEM0_VECTOR_STORE: Vector store provider (memory, pgvector, pinecone).
# Optional. Default: memory
# MEM0_VECTOR_STORE=pgvector

# MEM0_PGVECTOR_HOST: PostgreSQL host for Mem0 vector store.
# Optional. Default: localhost
# MEM0_PGVECTOR_HOST=localhost

# MEM0_PGVECTOR_PORT: PostgreSQL port for Mem0 vector store.
# Optional. Default: 5432
# MEM0_PGVECTOR_PORT=5432

# MEM0_PGVECTOR_USER: PostgreSQL user for Mem0 vector store.
# Optional. Default: hivemind
# MEM0_PGVECTOR_USER=hivemind

# MEM0_PGVECTOR_PASSWORD: PostgreSQL password for Mem0 vector store.
# Required if using pgvector. Example: your-postgres-password
# MEM0_PGVECTOR_PASSWORD=your-postgres-password

# MEM0_PGVECTOR_DATABASE: PostgreSQL database name for Mem0 vector store.
# Optional. Default: hivemind
# MEM0_PGVECTOR_DATABASE=hivemind

# MEM0_PGVECTOR_COLLECTION: Collection name for Mem0 memories.
# Optional. Default: mem0_memories
# MEM0_PGVECTOR_COLLECTION=mem0_memories

# === Mem4ai (External API with adaptive personalization) ===
# Mem4ai is an external REST API for memory management.
# Requires: Mem4ai API URL and key

# MEM4AI_API_URL: Mem4ai API base URL.
# Optional. Example: https://api.mem4ai.com/v1
# MEM4AI_API_URL=https://api.mem4ai.com/v1

# MEM4AI_API_KEY: Mem4ai API key.
# Optional. Example: your-mem4ai-api-key
# MEM4AI_API_KEY=your-mem4ai-api-key

# MEM4AI_EMBEDDING_PROVIDER_ID: Reference to LLM provider for embeddings.
# Optional. Example: openai
# MEM4AI_EMBEDDING_PROVIDER_ID=openai

# MEM4AI_LLM_PROFILE_KEY: LLM profile key for embedding configuration.
# Optional. Example: default
# MEM4AI_LLM_PROFILE_KEY=default

# === MemVault (PostgreSQL + pgvector) ===
# Self-hosted RAG memory with hybrid vector/recency scoring.
# Requires: PostgreSQL with pgvector extension

# MEMVAULT_HOST: PostgreSQL server hostname.
# Optional. Default: localhost
# MEMVAULT_HOST=localhost

# MEMVAULT_PORT: PostgreSQL server port.
# Optional. Default: 5432
# MEMVAULT_PORT=5432

# MEMVAULT_DATABASE: PostgreSQL database name.
# Optional. Default: hivemind
# MEMVAULT_DATABASE=hivemind

# MEMVAULT_USER: PostgreSQL username.
# Optional. Default: hivemind
# MEMVAULT_USER=hivemind

# MEMVAULT_PASSWORD: PostgreSQL password.
# Required. Example: your-postgres-password
# MEMVAULT_PASSWORD=your-postgres-password

# MEMVAULT_VECTOR_DIMENSION: Embedding vector dimension.
# Optional. Default: 1536 (OpenAI text-embedding-3-small)
# MEMVAULT_VECTOR_DIMENSION=1536

# MEMVAULT_EMBEDDING_ENDPOINT: Custom embedding endpoint URL.
# Optional. Example: http://localhost:8000/v1
# MEMVAULT_EMBEDDING_ENDPOINT=http://localhost:8000/v1

# MEMVAULT_EMBEDDING_API_KEY: API key for embedding endpoint.
# Optional. Example: sk-your-embedding-key
# MEMVAULT_EMBEDDING_API_KEY=your-embedding-api-key

# MEMVAULT_EMBEDDING_MODEL: Embedding model name.
# Optional. Default: text-embedding-3-small
# MEMVAULT_EMBEDDING_MODEL=text-embedding-3-small

# MEMVAULT_EMBEDDING_PROVIDER_ID: Reference to LLM provider for embeddings.
# Optional. Example: openai
# MEMVAULT_EMBEDDING_PROVIDER_ID=openai

# MEMVAULT_LLM_PROFILE_KEY: LLM profile key for embedding configuration.
# Optional. Example: default
# MEMVAULT_LLM_PROFILE_KEY=default

# === Redis (for caching and sessions) ===

# REDIS_URL: Redis connection string.
# Optional. Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# Agent Behaviors & Modifiers
# ------------------------------------------------------------------------------

# MESSAGE_INTERROBANG_BONUS: Bonus chance modifier for interrobang messages (e.g., !?).
# Optional. Default: 0.1
MESSAGE_INTERROBANG_BONUS=0.1

# MESSAGE_MENTION_BONUS: Bonus chance when the bot is directly mentioned.
# Optional. Default: 0.5
MESSAGE_MENTION_BONUS=0.5

# MESSAGE_BOT_RESPONSE_MODIFIER: Modifier for responding to other bot messages (negative to reduce).
# Optional. Default: -1.0
MESSAGE_BOT_RESPONSE_MODIFIER=-1.0

# MESSAGE_PRIORITY_CHANNEL_BONUS: Bonus multiplier for responding in priority channels.
# Optional. Default: 0.8
MESSAGE_PRIORITY_CHANNEL_BONUS=0.8

# MESSAGE_PRIORITY_CHANNEL: Target priority channel ID.
# Optional. Example: your-priority-channel-id
# MESSAGE_PRIORITY_CHANNEL=your-priority-channel-id

# MESSAGE_RECENT_ACTIVITY_DECAY_RATE: Decay rate for message response based on recent history.
# Optional. Default: 0.5
MESSAGE_RECENT_ACTIVITY_DECAY_RATE=0.5

# MESSAGE_ACTIVITY_TIME_WINDOW: Time window (in milliseconds) used for activity calculations.
# Optional. Default: 300000 (5 minutes)
MESSAGE_ACTIVITY_TIME_WINDOW=300000

# MESSAGE_WAKEWORDS: Comma-separated wakewords that guarantee a response from the bot.
# Optional. Example: !help,!ping,!echo
MESSAGE_WAKEWORDS=!help,!ping,!echo

# ------------------------------------------------------------------------------
# Idle Response Configuration
# ------------------------------------------------------------------------------

# IDLE_RESPONSE_ENABLED: Enable or disable proactive idle responses.
# Optional. Default: false
IDLE_RESPONSE_ENABLED=false

# IDLE_RESPONSE_MIN_DELAY: Minimum delay (in ms) before sending an idle response.
# Optional. Default: 600000 (10 minutes)
IDLE_RESPONSE_MIN_DELAY=600000

# IDLE_RESPONSE_MAX_DELAY: Maximum delay (in ms) before sending an idle response.
# Optional. Default: 3600000 (1 hour)
IDLE_RESPONSE_MAX_DELAY=3600000

# DUPLICATE_DETECTOR_CLEANUP_INTERVAL_MS: Interval to clear duplicate messaging caches.
# Optional. Default: 300000
# DUPLICATE_DETECTOR_CLEANUP_INTERVAL_MS=300000

# DUPLICATE_DETECTOR_MAX_CHANNELS: Memory size cap for the duplicate message detector state.
# Optional. Default: 100
# DUPLICATE_DETECTOR_MAX_CHANNELS=100

# ------------------------------------------------------------------------------
# Frontend / Client Configuration (Vite)
# ------------------------------------------------------------------------------

# VITE_API_BASE_URL: URL used by the React client to make backend API calls.
# Optional. Example: http://localhost:3000
# VITE_API_BASE_URL=

# VITE_AUTO_LOGIN: Enable auto-login bypass for development mode in the UI.
# Optional. Default: false
# VITE_AUTO_LOGIN=false
