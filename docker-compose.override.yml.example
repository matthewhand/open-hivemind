# docker-compose.override.yml.example
#
# Auxiliary services for Open Hivemind: Postgres database and self-hosted Mem0 memory provider.
#
# Usage:
#   cp docker-compose.override.yml.example docker-compose.override.yml
#   cp .env.mem0.example .env.mem0
#   # Edit .env.mem0 — at minimum set OPENAI_API_KEY (or switch to Ollama)
#   docker compose up -d
#
# Docker Compose automatically merges docker-compose.override.yml on top of
# docker-compose.yml, so the services come up alongside hivemind.

services:
  # ---------------------------------------------------------------------------
  # Primary PostgreSQL (for configuration and log persistence)
  # ---------------------------------------------------------------------------
  postgres:
    image: postgres:16-alpine
    restart: unless-stopped
    environment:
      - POSTGRES_USER=hivemind
      - POSTGRES_PASSWORD=hivemind_secret
      - POSTGRES_DB=hivemind
    ports:
      - "127.0.0.1:5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U hivemind -d hivemind"]
      interval: 10s
      timeout: 5s
      retries: 5
    volumes:
      - postgres_data:/var/lib/postgresql/data

  # ---------------------------------------------------------------------------
  # Mem0 API server (FastAPI)
  # ---------------------------------------------------------------------------
  mem0:
    build: ./docker/mem0
    ports:
      - "127.0.0.1:8888:8000"
    env_file:
      - .env.mem0
    environment:
      - POSTGRES_HOST=mem0-postgres
      - POSTGRES_PORT=5432
      - POSTGRES_DB=mem0
      - POSTGRES_USER=mem0
      - POSTGRES_PASSWORD=mem0secret
      - POSTGRES_COLLECTION_NAME=memories
      - NEO4J_URI=bolt://mem0-neo4j:7687
      - NEO4J_USERNAME=neo4j
      - NEO4J_PASSWORD=mem0graph
    networks:
      - default
      - mem0_network
    depends_on:
      mem0-postgres:
        condition: service_healthy
      mem0-neo4j:
        condition: service_healthy
    volumes:
      - mem0_history:/app/history
    healthcheck:
      test: ["CMD", "curl", "-sfL", "http://localhost:8000/"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    restart: unless-stopped

  # ---------------------------------------------------------------------------
  # PostgreSQL + pgvector (for Mem0 vector embeddings storage)
  # ---------------------------------------------------------------------------
  mem0-postgres:
    image: ankane/pgvector:v0.5.1
    restart: unless-stopped
    shm_size: "128mb"
    networks:
      - mem0_network
    environment:
      - POSTGRES_USER=mem0
      - POSTGRES_PASSWORD=mem0secret
      - POSTGRES_DB=mem0
    healthcheck:
      test: ["CMD", "pg_isready", "-q", "-d", "mem0", "-U", "mem0"]
      interval: 5s
      timeout: 5s
      retries: 5
    volumes:
      - mem0_postgres_data:/var/lib/postgresql/data
    ports:
      - "127.0.0.1:8432:5432"

  # ---------------------------------------------------------------------------
  # Neo4j (entity relationship graph for memory associations)
  # ---------------------------------------------------------------------------
  mem0-neo4j:
    image: neo4j:5.26.4
    restart: unless-stopped
    networks:
      - mem0_network
    environment:
      - NEO4J_AUTH=neo4j/mem0graph
      - NEO4J_PLUGINS=["apoc"]
      - NEO4J_apoc_export_file_enabled=true
      - NEO4J_apoc_import_file_enabled=true
      - NEO4J_apoc_import_file_use__neo4j__config=true
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost:7474"]
      interval: 10s
      timeout: 10s
      retries: 20
      start_period: 90s
    volumes:
      - mem0_neo4j_data:/data
    ports:
      - "127.0.0.1:8474:7474"
      - "127.0.0.1:8687:7687"

  # ---------------------------------------------------------------------------
  # Letta — self-hosted stateful agent server (REST API on port 8283)
  # ---------------------------------------------------------------------------
  letta:
    image: letta/letta:latest
    ports:
      - "127.0.0.1:8283:8283"
    environment:
      - OPENAI_API_KEY=${OPENAI_API_KEY:-}
      - OPENAI_API_BASE=${OPENAI_API_BASE:-}
      - SECURE=true
      - LETTA_SERVER_PASSWORD=${LETTA_SERVER_PASSWORD}
    volumes:
      - letta_pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:8283/v1/health/"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 30s
    restart: unless-stopped

volumes:
  postgres_data:
  mem0_postgres_data:
  mem0_neo4j_data:
  mem0_history:
  letta_pgdata:

networks:
  mem0_network:
    driver: bridge
