{
  // TypeScript config for OpenWebUI provider with proper module resolution
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@hivemind/shared-types": ["../shared-types/src"],
      "@src/*": ["../../src/*"],
      "@config/*": ["../../src/config/*"],
      "@message/*": ["../../src/message/*"],
      "@types/*": ["../../src/types/*"],
      "@server/*": ["../../src/server/*"],
      "@services/*": ["../../src/services/*"],
      "@llm/*": ["../../src/llm/*"],
    }
  },
  "include": ["src/**/*", "../../src/message/interfaces/IMessage.ts", "../../src/llm/interfaces/ILlmProvider.ts"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../shared-types" }
  ]
}
