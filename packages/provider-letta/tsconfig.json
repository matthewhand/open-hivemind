{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@hivemind/shared-types": ["../shared-types/src"],
      "@llm/interfaces/ILlmProvider": ["../../src/llm/interfaces/ILlmProvider"],
      "@message/interfaces/IMessage": ["../../src/message/interfaces/IMessage"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
