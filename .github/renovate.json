{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "packageRules": [
    {
      "matchPackagePatterns": ["typescript", "jest", "@types/node"],
      "groupName": "shared dev dependencies",
      "automerge": false
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    }
  ],
  "ignorePaths": ["**/node_modules/**", "**/pnpm-lock.yaml"]
}
