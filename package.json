{
  "name": "open-hivemind",
  "version": "1.0.0",
  "description": "A messenger bot to communicate with LLMs",
  "type": "commonjs",
  "bin": {
    "hivemind": "dist/src/cli/HivemindCLI.js"
  },
  "workspaces": [
    "src/client",
    "packages/*"
  ],
  "scripts": {
    "lint": "node ./node_modules/eslint/bin/eslint.js src/",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js src/ --fix",
    "format": "node ./node_modules/prettier/bin/prettier.cjs --write \"src/**/*.ts\" \"src/**/*.tsx\" \"tests/**/*.ts\" \"packages/**/*.ts\"",
    "format:check": "node ./node_modules/prettier/bin/prettier.cjs --check \"src/**/*.ts\" \"src/**/*.tsx\" \"tests/**/*.ts\" \"packages/**/*.ts\"",
    "check-types": "tsc --noEmit || true",
    "version": "tsc -v",
    "build": "bash ./scripts/build-all.sh",
    "build:backend": "bash ./scripts/build-backend.sh",
    "build:frontend": "bash ./scripts/build-frontend.sh",
    "build:netlify": "bash ./scripts/build-netlify.sh",
    "build:serverless": "npm run build:frontend && mkdir -p api && cp src/api/index.js api/index.js",
    "start": "NODE_ENV=production bash ./scripts/start-runtime.sh",
    "start:test": "NODE_ENV=test bash ./scripts/start-runtime.sh",
    "start:headless": "NODE_ENV=production HTTP_ENABLED=false bash ./scripts/start-runtime.sh",
    "start:dev:headless": "NODE_ENV=development HTTP_ENABLED=false node node_modules/.bin/ts-node --project tsconfig.json -r tsconfig-paths/register src/index.ts",
    "start:dev": "NODE_ENV=development node node_modules/.bin/ts-node --project tsconfig.json -r tsconfig-paths/register src/index.ts",
    "dev:frontend-only": "cd src/client && ../../node_modules/.bin/vite --port 3028 --host",
    "dev:webui-only": "SKIP_MESSENGERS=true npm run start:dev",
    "dev": "npm run start:dev",
    "dev:clean": "rm -rf dist node_modules/.cache",
    "dev:status": "ps aux | grep -E '(node|ts-node)' | grep -v grep",
    "audit:secrets": "bash ./scripts/audit-secrets.sh",
    "validate": "./node_modules/.bin/concurrently \"npm run lint\" \"npm run test\"",
    "test": "NODE_CONFIG_DIR=config/test/ NODE_ENV=test node -r dotenv/config node_modules/.bin/jest --runInBand",
    "test:coverage": "NODE_CONFIG_DIR=config/test/ NODE_ENV=test node_modules/.bin/jest --coverage --runInBand",
    "test:real": "NODE_ENV=test jest --config jest.real.config.js",
    "test:real:legacy": "./scripts/run-real-tests.sh",
    "test:debug": "NODE_CONFIG_DIR=config/test/ NODE_ENV=test DEBUG=* jest --verbose --runInBand",
    "test:monitor": "NODE_CONFIG_DIR=config/test/ NODE_ENV=test DEBUG=* jest --verbose --runInBand --watch",
    "test:e2e": "NODE_CONFIG_DIR=config/test/ NODE_ENV=test node_modules/.bin/mocha tests/e2e/simple-dashboard-test.mjs --timeout 30000",
    "test:e2e:ci": "NODE_CONFIG_DIR=config/test/ NODE_ENV=test TEST_SERVER_RUNNING=true node_modules/.bin/mocha tests/e2e/simple-dashboard-test.mjs --timeout 30000 --reporter spec",
    "test:e2e:watch": "NODE_CONFIG_DIR=config/test/ NODE_ENV=test node_modules/.bin/mocha tests/e2e/simple-dashboard-test.mjs --timeout 30000 --watch",
    "test:playwright": "node ./node_modules/.bin/playwright test",
    "generate-docs": "mkdir -p docs/screenshots && node ./node_modules/.bin/playwright test tests/e2e/screenshot-*.spec.ts --project=chromium",
    "docs:screenshots": "npx playwright test tests/e2e/docs-screenshots.spec.ts",
    "playwright:serve": "RUNTIME_BUILD_ON_START=true NODE_ENV=production bash ./scripts/start-runtime.sh",
    "ncu": "ncu",
    "dev:only": "npm run dev",
    "dev:only:backend": "npm run dev:backend",
    "dev:only:frontend": "npm run dev:frontend",
    "build:only": "npm run build",
    "build:only:backend": "npm run build:backend",
    "build:only:frontend": "npm run build:frontend",
    "test:only": "npm run test",
    "test:only:backend": "npm run test:backend",
    "test:only:frontend": "npm run test:frontend"
  },
  "_moduleAliases": {
    "@src": "dist/src",
    "@command": "dist/src/command",
    "@common": "dist/src/common",
    "@config": "dist/src/config",
    "@auth": "dist/src/auth",
    "@llm": "dist/src/llm",
    "@message": "dist/src/message",
    "@webhook": "dist/src/webhook",
    "@integrations": "dist/src/integrations",
    "@types": "dist/src/types",
    "@client": "dist/src/client",
    "@server": "dist/src/server",
    "@hivemind/provider-openai": "dist/packages/provider-openai/src",
    "@hivemind/provider-letta": "dist/packages/provider-letta/src",
    "@hivemind/memory-mem4ai": "dist/packages/memory-mem4ai/src",
    "@hivemind/memory-memvault": "dist/packages/memory-memvault/src",
    "@hivemind/adapter-discord": "dist/packages/adapter-discord/src",
    "@hivemind/adapter-slack": "dist/packages/adapter-slack/src",
    "@hivemind/adapter-mattermost": "dist/packages/adapter-mattermost/src"
  },
  "keywords": [],
  "author": "matthewhand+dot+au+at+gmail+dot+com",
  "license": "MIT",
  "dependencies": {
    "@discordjs/voice": "^0.18.0",
    "@heroicons/react": "^2.2.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@slack/rtm-api": "^7.0.2",
    "@slack/socket-mode": "^2.0.3",
    "@slack/web-api": "^7.8.0",
    "async-mutex": "^0.5.0",
    "async-retry": "^1.3.3",
    "axios": "^1.6.5",
    "bcrypt": "^6.0.0",
    "chalk": "^5.6.2",
    "classnames": "^2.5.1",
    "commander": "^14.0.3",
    "config": "^4.4.1",
    "convict": "^6.2.4",
    "cors": "^2.8.6",
    "daisyui": "^5.5.19",
    "debug": "^4.3.7",
    "discord.js": "^14.14.1",
    "dompurify": "^3.3.1",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.1",
    "flowise-sdk": "^1.0.8",
    "form-data": "^4.0.5",
    "framer-motion": "^12.34.3",
    "html-entities": "^2.6.0",
    "inquirer": "^13.3.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.2.6",
    "lucide-react": "^0.460.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "openai": "^4.82.0",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.58.2",
    "prop-types": "^15.8.1",
    "puppeteer": "^24.23.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^2.15.4",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "retry": "^0.13.1",
    "sitemap": "^9.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sqlite": "^5.1.1",
    "tailwind-merge": "^3.5.0",
    "tsyringe": "^4.10.0",
    "uuid": "^11.1.0",
    "yargs": "^18.0.0",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-transform-class-properties": "^7.24.7",
    "@babel/plugin-transform-object-rest-spread": "^7.24.1",
