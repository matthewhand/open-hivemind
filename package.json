    "@testing-library/react": "^16.3.0",
    "@types/async-retry": "^1.4.9",
    "@types/bcrypt": "^6.0.0",
    "@types/config": "^3.3.5",
    "@types/convict": "^6.1.6",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.12",
    "@types/dompurify": "^3.0.5",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^4.17.21",
