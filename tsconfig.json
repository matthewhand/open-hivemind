{
  "compilerOptions": {
    "target": "es2018",
    "lib": [
      "es2021",
      "dom"
    ],
    "module": "CommonJS",
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitThis": false,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": "./",
    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ],
    "types": [
      "jest",
      "node"
    ],
    "incremental": true,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "downlevelIteration": true,
    "jsx": "react",
    "forceConsistentCasingInFileNames": false,
    "isolatedModules": false,
    "paths": {
      "@command/*": [
        "src/command/*"
      ],
      "@common/*": [
        "src/common/*"
      ],
      "@config/*": [
        "src/config/*"
      ],
      "@llm/*": [
        "src/llm/*"
      ],
      "@message/*": [
        "src/message/*"
      ],
      "@webhook/*": [
        "src/webhook/*"
      ],
      "@integrations/*": [
        "src/integrations/*"
      ],
      "@types/*": [
        "src/types/*"
      ],
      "@src/integrations/slack/*": [
        "packages/adapter-slack/src/*"
      ],
      "@src/integrations/mattermost/*": [
        "packages/adapter-mattermost/src/*"
      ],
      "@hivemind/shared-types": [
        "packages/shared-types/src/index.ts"
      ],
      "@hivemind/shared-types/*": [
        "packages/shared-types/src/*"
      ],
      "@src/*": [
        "src/*"
      ],
      "@tests/*": [
        "tests/*"
      ],
      "testUtils": [
        "./tests/testUtils"
      ],
      "@hivemind/llm-openai": [
        "packages/llm-openai/src/index.ts"
      ],
      "@hivemind/llm-openai/*": [
        "packages/llm-openai/src/*"
      ],
      "@hivemind/memory-mem4ai": [
        "packages/memory-mem4ai/src/index.ts"
      ],
      "@hivemind/memory-mem4ai/*": [
        "packages/memory-mem4ai/src/*"
      ],
      "@hivemind/memory-memvault": [
        "packages/memory-memvault/src/index.ts"
      ],
      "@hivemind/memory-memvault/*": [
        "packages/memory-memvault/src/*"
      ],
      "@hivemind/message-discord": [
        "packages/message-discord/src/index.ts"
      ],
      "@hivemind/message-discord/*": [
        "packages/message-discord/src/*"
      ],
      "@hivemind/message-slack": [
        "packages/message-slack/src/index.ts"
      ],
      "@hivemind/message-slack/*": [
        "packages/message-slack/src/*"
      ],
      "@hivemind/message-mattermost": [
        "packages/message-mattermost/src/index.ts"
      ],
      "@hivemind/adapter-mattermost/*": [
        "packages/adapter-mattermost/src/*"
      ],
      "@hivemind/llm-letta": [
        "packages/llm-letta/src/index.ts"
      ],
      "@hivemind/llm-letta/*": [
        "packages/llm-letta/src/*"
      ]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": [
    "src/**/*",
    "packages/llm-openai/src/**/*",
    "packages/memory-mem4ai/src/**/*",
    "packages/memory-memvault/src/**/*",
    "packages/message-discord/src/**/*",
    "packages/message-slack/src/**/*",
    "packages/message-mattermost/src/**/*"
  ],
  "exclude": [
    "tests/**/*",
    "node_modules",
    "src/client/**/*"
  ],
  "files": [
    "src/global.d.ts"
  ]
}