{
  "compilerOptions": {
    "target": "es2018",
    "lib": [
      "es2021",
      "dom"
    ],
    "module": "CommonJS",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitThis": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": "./",
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "types": ["jest", "node"],
    "incremental": true,
    "skipLibCheck": true,
    "noEmitOnError": true,
    "downlevelIteration": true,
    "jsx": "react",
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": false,
    "paths": {
      "@command/*": ["src/command/*"],
      "@common/*": ["src/common/*"],
      "@config/*": ["src/config/*"],
      "@llm/*": ["src/llm/*"],
      "@message/*": ["src/message/*"],
      "@webhook/*": ["src/webhook/*"],
      "@integrations/flowise/*": ["packages/llm-flowise/src/*"],
      "@integrations/openwebui/*": ["packages/llm-openwebui/src/*"],
      "@integrations/openswarm/*": ["packages/llm-openswarm/src/*"],
      "@types/*": ["src/types/*"],
      "@src/integrations/slack/*": ["packages/message-slack/src/*"],
      "@src/integrations/mattermost/*": ["packages/message-mattermost/src/*"],
      "@hivemind/shared-types": ["packages/shared-types/src/index.ts"],
      "@hivemind/shared-types/*": ["packages/shared-types/src/*"],
      "@src/*": ["src/*"],
      "@tests/*": ["tests/*"],
      "testUtils": ["./tests/testUtils"],
      "@hivemind/llm-openai": ["packages/llm-openai/src/index.ts"],
      "@hivemind/llm-openai/*": ["packages/llm-openai/src/*"],
      "@hivemind/llm-letta": ["packages/llm-letta/src/index.ts"],
      "@hivemind/llm-letta/*": ["packages/llm-letta/src/*"],
      "@hivemind/message-discord": ["packages/message-discord/src/index.ts"],
      "@hivemind/message-discord/*": ["packages/message-discord/src/*"],
      "@hivemind/message-slack": ["packages/message-slack/src/index.ts"],
      "@hivemind/message-slack/*": ["packages/message-slack/src/*"],
      "@hivemind/message-mattermost": ["packages/message-mattermost/src/index.ts"],
      "@hivemind/message-mattermost/*": ["packages/message-mattermost/src/*"],
      "@hivemind/message-webhook": ["packages/message-webhook/src/index.ts"],
      "@hivemind/message-webhook/*": ["packages/message-webhook/src/*"],
      "@hivemind/memory-mem0": ["packages/memory-mem0/src/index.ts"],
      "@hivemind/memory-mem0/*": ["packages/memory-mem0/src/*"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": [
    "src/**/*",
    "packages/llm-openai/src/**/*",
    "packages/llm-openswarm/src/**/*",
    "packages/llm-flowise/src/**/*",
    "packages/llm-openwebui/src/**/*",
    "packages/llm-letta/src/**/*",
    "packages/message-discord/src/**/*",
    "packages/message-slack/src/**/*",
    "packages/message-mattermost/src/**/*",
    "packages/message-webhook/src/**/*"
  ],
  "exclude": ["tests/**/*", "node_modules", "src/client/**/*", "packages/**/*.test.ts"],
  "files": ["src/global.d.ts"]
}
