# .env.mem0.example
#
# Configuration for the self-hosted Mem0 memory service.
# Copy to .env.mem0 and fill in your values.
#
# Required: at least one LLM API key for fact extraction + embeddings.
# The default config uses OpenAI. For fully offline, switch to Ollama below.

# --- LLM for memory extraction (required) ---
OPENAI_API_KEY=sk-your-openai-key-here

# --- Optional: API key to protect the Mem0 API ---
# When set, all requests must include header: Authorization: Token <key>
# ADMIN_API_KEY=change-me-to-a-strong-secret

# --- Fully offline alternative (Ollama) ---
# Uncomment these and remove OPENAI_API_KEY to use local models:
# LLM_PROVIDER=ollama
# LLM_MODEL=phi3:mini
# EMBEDDER_PROVIDER=ollama
# EMBEDDER_MODEL=nomic-embed-text
# OLLAMA_BASE_URL=http://host.docker.internal:11434
